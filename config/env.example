# MLX OpenAI server base URLs
# Example: http://192.168.1.72:8100/v1
UI_USERNAME=admin
UI_PASSWORD=change-me
SEARXNG_API_BASE=http://127.0.0.1:8888
SEARXNG_API_KEY=
HEALTH_CHECK_TIMEOUT_SECONDS=5

# BEGIN MLXCTL AUTO
# MLX OpenAI server base URLs (auto-generated)
MLX_MLX_GPT_OSS_120B_MXFP4_Q4_API_BASE=http://192.168.1.72:8100/v1
MLX_MLX_QWEN3_NEXT_80B_MXFP4_A3B_INSTRUCT_API_BASE=http://192.168.1.72:8101/v1
MLX_MLX_GPT_OSS_20B_MXFP4_Q4_API_BASE=http://192.168.1.72:8102/v1

# Upstream model IDs (prefix with "openai/" for OpenAI-compatible backends)
MLX_MLX_GPT_OSS_120B_MXFP4_Q4_MODEL=openai/mlx-gpt-oss-120b-mxfp4-q4
MLX_MLX_QWEN3_NEXT_80B_MXFP4_A3B_INSTRUCT_MODEL=openai/mlx-qwen3-next-80b-mxfp4-a3b-instruct
MLX_MLX_GPT_OSS_20B_MXFP4_Q4_MODEL=openai/mlx-gpt-oss-20b-mxfp4-q4

# Active MLX team lanes no longer require backend API keys.
# END MLXCTL AUTO

# Temporary experimental aliases (vllm-metal on 8120-8139)
METAL_TEST_FAST_API_BASE=http://192.168.1.72:8120/v1
METAL_TEST_FAST_MODEL=openai/default_model
METAL_TEST_FAST_API_KEY=dummy
METAL_TEST_MAIN_API_BASE=http://192.168.1.72:8121/v1
METAL_TEST_MAIN_MODEL=openai/default_model
METAL_TEST_MAIN_API_KEY=dummy
METAL_TEST_DEEP_API_BASE=http://192.168.1.72:8122/v1
METAL_TEST_DEEP_MODEL=openai/default_model
METAL_TEST_DEEP_API_KEY=dummy

# Alias notes
# - Omni is the canonical MLX endpoint (8100). Model selection is by `model` field.
# - "main" uses qwen3-next-80b (served by Omni)
# - "deep" uses gpt-oss-120b (served by Omni)
# - "fast" uses gpt-oss-20b (served by Omni)
# - `voice-*` aliases route to the Orin voice-gateway LAN `/v1` facade.
# - `metal-test-*` aliases are temporary and experiment-scoped.
# Voice Gateway speech appliance (Orin)
VOICE_GATEWAY_API_BASE=http://192.168.1.93:18080/v1
VOICE_GATEWAY_API_KEY=change-me

# - Open WebUI web search should use documented native env vars on the Open WebUI service.
# Open WebUI native web search (set these on the Open WebUI service, not LiteLLM)
# WEB_SEARCH_ENGINE=searxng
# SEARXNG_QUERY_URL=http://127.0.0.1:8888/search?q=<query>&format=json
# WEB_LOADER_ENGINE=safe_web
# WEB_FETCH_FILTER_LIST=!localhost,!127.0.0.1,!192.168.1.70,!192.168.1.71,!192.168.1.72,!100.69.99.60,!code.tailfd1400.ts.net,!chat.tailfd1400.ts.net,!gateway.tailfd1400.ts.net,!search.tailfd1400.ts.net
# WEB_SEARCH_DOMAIN_FILTER_LIST=!localhost,!127.0.0.1,!192.168.1.70,!192.168.1.71,!192.168.1.72,!100.69.99.60,!code.tailfd1400.ts.net,!chat.tailfd1400.ts.net,!gateway.tailfd1400.ts.net,!search.tailfd1400.ts.net
