# MLX OpenAI server base URLs
# Example: http://192.168.1.72:8100/v1
JERRY_XL_API_BASE=http://<studio-host>:8100/v1
JERRY_L_API_BASE=http://<studio-host>:8101/v1
JERRY_M_API_BASE=http://<studio-host>:8102/v1
JERRY_S_API_BASE=http://<studio-host>:8103/v1
BENCH_XL_API_BASE=http://<studio-host>:8104/v1
BENCH_L_API_BASE=http://<studio-host>:8105/v1
BENCH_M_API_BASE=http://<studio-host>:8106/v1
BENCH_S_API_BASE=http://<studio-host>:8107/v1
UTILITY_A_API_BASE=http://<studio-host>:8108/v1
UTILITY_B_API_BASE=http://<studio-host>:8109/v1

# Upstream model IDs (prefix with "openai/" for OpenAI-compatible backends)
JERRY_XL_MODEL=openai/<upstream-model-id>
JERRY_L_MODEL=openai/<upstream-model-id>
JERRY_M_MODEL=openai/<upstream-model-id>
JERRY_S_MODEL=openai/<upstream-model-id>
BENCH_XL_MODEL=openai/<upstream-model-id>
BENCH_L_MODEL=openai/<upstream-model-id>
BENCH_M_MODEL=openai/<upstream-model-id>
BENCH_S_MODEL=openai/<upstream-model-id>
UTILITY_A_MODEL=openai/<upstream-model-id>
UTILITY_B_MODEL=openai/<upstream-model-id>

# API keys (set to "dummy" if the backend does not enforce auth)
JERRY_XL_API_KEY=dummy
JERRY_L_API_KEY=dummy
JERRY_M_API_KEY=dummy
JERRY_S_API_KEY=dummy
BENCH_XL_API_KEY=dummy
BENCH_L_API_KEY=dummy
BENCH_M_API_KEY=dummy
BENCH_S_API_KEY=dummy
UTILITY_A_API_KEY=dummy
UTILITY_B_API_KEY=dummy
