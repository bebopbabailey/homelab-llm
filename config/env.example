# MLX OpenAI server base URLs
# Example: http://192.168.1.72:8100/v1
JERRY_WEAK_API_BASE=http://<studio-host>:8103/v1
JERRY_EDITOR_API_BASE=http://<studio-host>:8101/v1
JERRY_ARCHITECT_API_BASE=http://<studio-host>:8102/v1
JERRY_CHAT_API_BASE=http://<studio-host>:8100/v1
LIL_JERRY_API_BASE=http://localhost:9000/v1

# Upstream model IDs (prefix with "openai/" for OpenAI-compatible backends)
JERRY_WEAK_MODEL=openai/<upstream-model-id>
JERRY_EDITOR_MODEL=openai/<upstream-model-id>
JERRY_ARCHITECT_MODEL=openai/<upstream-model-id>
JERRY_CHAT_MODEL=openai/<upstream-model-id>
LIL_JERRY_MODEL=openai/<upstream-model-id>

# API keys (set to "dummy" if the backend does not enforce auth)
JERRY_WEAK_API_KEY=dummy
JERRY_EDITOR_API_KEY=dummy
JERRY_ARCHITECT_API_KEY=dummy
JERRY_CHAT_API_KEY=dummy
LIL_JERRY_API_KEY=dummy
