UPSTREAM_SEARXNG_URL=http://127.0.0.1:8888/search
SEARCH_TOP_N=24
SEARCH_KEEP_K=8
REQUEST_TIMEOUT_SECONDS=12
MAX_RESULTS_PER_DOMAIN=2
FILTER_BLOCK_PATTERNS=javascript is disabled|captcha|verify you.*robot|invalid parameter|access denied|enable js and disable
FILTER_BLOCK_DOMAINS=facebook.com,tiktok.com,quora.com
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8899

# Optional local semantic reranker (fail-open)
RERANK_ENABLED=false
RERANK_MODEL=ms-marco-TinyBERT-L-2-v2
RERANK_CACHE_DIR=/tmp/websearch-orch-rerank
RERANK_MAX_DOC_CHARS=1400
RERANK_TOP_N=8
RERANK_KEEP_K=8
RERANK_MODEL_MAX_LENGTH=512
RERANK_LOG_TOP=5

# Optional external web-loader endpoint for Open WebUI WEB_LOADER_ENGINE=external
EXTERNAL_WEB_LOADER_ENABLED=true
EXTERNAL_WEB_LOADER_PATH=/web_loader
EXTERNAL_WEB_LOADER_API_KEY=
EXTERNAL_WEB_LOADER_MAX_URLS=20
EXTERNAL_WEB_LOADER_MAX_BODY_BYTES=200000
EXTERNAL_WEB_LOADER_FETCH_TIMEOUT_SECONDS=20
EXTERNAL_WEB_LOADER_MAX_PAGE_BYTES=1500000
EXTERNAL_WEB_LOADER_MIN_TEXT_CHARS=120
EXTERNAL_WEB_LOADER_MAX_TEXT_CHARS=8000
EXTERNAL_WEB_LOADER_USER_AGENT=websearch-orch/1.1 (+https://github.com/open-webui/open-webui)
