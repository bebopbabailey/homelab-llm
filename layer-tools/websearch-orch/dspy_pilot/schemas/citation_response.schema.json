{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CitationResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "answer_text": {
      "type": "string",
      "minLength": 1
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "source_id": {
            "type": "integer",
            "minimum": 1
          },
          "url": {
            "type": "string",
            "format": "uri",
            "minLength": 1
          },
          "claim_span": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "source_id",
          "url",
          "claim_span"
        ]
      }
    }
  },
  "required": [
    "answer_text",
    "citations"
  ]
}
