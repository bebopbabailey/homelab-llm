def _run(cmd, *, input_bytes=None, check=True):
    result = subprocess.run(
        cmd,
        input=input_bytes,
        capture_output=True,
        text=False,
        check=False,
    )
    if check and result.returncode != 0:
        stderr = (result.stderr or b"").decode("utf-8", errors="replace")
        raise SystemExit(f"command failed (exit {result.returncode}): {' '.join(cmd)}\n{stderr}")
    return result


def _sha256_path(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _studio_ssh_target() -> str:
    return os.environ.get("STUDIO_SSH") or os.environ.get("STUDIO_HOST", "studio")


def _studio_host_label() -> str:
    return _studio_ssh_target().split("@", 1)[-1]


def _studio_utility_wrapper():
    if os.environ.get("STUDIO_UTILITY_WRAPPER_DISABLE", "").strip().lower() in {"1", "true", "yes"}:
        return None
    configured = os.environ.get("STUDIO_UTILITY_WRAPPER", DEFAULT_STUDIO_UTILITY_WRAPPER)
    candidate = Path(configured)
    if candidate.exists() and candidate.is_file():
        return str(candidate)
    return None


def _ssh_cmd(studio_ssh: str, argv, *, input_bytes=None, check=True):
    # IMPORTANT: `ssh host cmd arg...` is re-serialized into a single command line on
    # the remote side, so argument boundaries are not preserved. Always send a single
    # quoted command string to be executed by `bash -lc`.
    if isinstance(argv, str):
        remote = argv
    else:
        remote = " ".join(shlex.quote(part) for part in argv)
    host = studio_ssh.split("@", 1)[-1].strip().lower()
    if _is_local_host() and host in {"studio", "localhost", "127.0.0.1", "192.168.1.72"}:
        return _run(["bash", "-lc", remote], input_bytes=input_bytes, check=check)
    wrapper = _studio_utility_wrapper()
    if wrapper:
        return _run(
            [wrapper, "--host", studio_ssh, "--", "bash -lc " + shlex.quote(remote)],
            input_bytes=input_bytes,
            check=check,
        )
    cmd = "bash -lc " + shlex.quote(remote)
    return _run(["ssh", studio_ssh, cmd], input_bytes=input_bytes, check=check)


def _studio_sudo_cmd(studio_ssh: str, argv, *, input_bytes=None, check=True):
    # Same ssh boundary issue as _ssh_cmd: build a single quoted remote command string.
    if isinstance(argv, str):
        remote = argv
    else:
        remote = " ".join(shlex.quote(part) for part in argv)
    host = studio_ssh.split("@", 1)[-1].strip().lower()
    if _is_local_host() and host in {"studio", "localhost", "127.0.0.1", "192.168.1.72"}:
        return _run(["sudo", "-n", "bash", "-lc", remote], input_bytes=input_bytes, check=check)
    wrapper = _studio_utility_wrapper()
    if wrapper:
        return _run(
            [wrapper, "--host", studio_ssh, "--sudo", "--", "bash -lc " + shlex.quote(remote)],
            input_bytes=input_bytes,
            check=check,
        )
    cmd = "sudo -n bash -lc " + shlex.quote(remote)
    return _run(["ssh", studio_ssh, cmd], input_bytes=input_bytes, check=check)


def _read_patch_bytes(path: Path) -> bytes:
    if not path.exists():
        raise SystemExit(f"missing patch file: {path}")
    return path.read_bytes()


def _loads_json_or_die(raw: str, *, context: str, default: str = "{}"):
    text = raw if raw is not None else default
    if not str(text).strip():
        text = default
    try:
        return json.loads(text)
    except json.JSONDecodeError as exc:
        raise SystemExit(
            f"{context}: invalid JSON at line {exc.lineno}, column {exc.colno}: {exc.msg}"
        )


def _parse_int_arg(value, *, arg_name: str) -> int:
    try:
        return int(str(value).strip())
    except (TypeError, ValueError):
        raise SystemExit(f"{arg_name} must be an integer (got {value!r})")


def _parse_port_arg(value, *, arg_name: str, valid_range=PORT_RANGE, range_label: str = "8100-8139") -> int:
    port = _parse_int_arg(value, arg_name=arg_name)
    if valid_range is not None and port not in valid_range:
        raise SystemExit(f"{arg_name} must be in {range_label} (got {port})")
    return port


def _parse_port_csv(raw_ports: Optional[str], *, arg_name: str, valid_range=TEAM_RANGE, range_label: str = "8100-8119"):
    ports = []
    if not raw_ports:
        return ports
    for raw in str(raw_ports).split(","):
        token = raw.strip()
        if not token:
            continue
        ports.append(
            _parse_port_arg(token, arg_name=arg_name, valid_range=valid_range, range_label=range_label)
        )
    return sorted(set(ports))


def _is_local_host():
    host = socket.gethostname().split(".")[0].lower()
    if host in {"studio", "thestudio"}:
        return True
    return Path(DEFAULT_HF_HOME).exists() and Path(DEFAULT_VLLM_BIN).exists()


def _maybe_forward_to_studio(args):
    if args.local:
        return
    if getattr(args, "command", None) == "offload-og":
        return
    if getattr(args, "command", None) == "sync-gateway":
        return
    if getattr(args, "command", None) in {"studio-cli-sha", "sync-studio-cli"}:
        return
    # Omni + cutover ops orchestrate Studio actions from the caller host.
    if getattr(args, "command", None) in {
        "omni-install",
        "omni-stop",
        "omni-status",
        "mlx-launch-stop",
        "mlx-launch-start",
        "repair-lanes",
        "mlx-launch-configure-vllm",
    }:
        return
    if getattr(args, "command", None) == "assign-team":
        return
    if _is_local_host():
        return
    studio_host = _studio_ssh_target()
    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    cmd = ["ssh", studio_host, studio_cmd, "--local"] + sys.argv[1:]
    raise SystemExit(subprocess.call(cmd))


def _studio_cli_sha(studio_host: str, studio_cmd: str) -> Optional[str]:
    script = f"""
import hashlib
from pathlib import Path

path = Path({studio_cmd!r})
if not path.exists():
    raise SystemExit(2)
h = hashlib.sha256()
with path.open("rb") as handle:
    for chunk in iter(lambda: handle.read(1024 * 1024), b""):
        h.update(chunk)
print(h.hexdigest())
"""
    result = subprocess.run(
        ["ssh", studio_host, "python3", "-"],
        input=script.encode("utf-8"),
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    value = result.stdout.decode("utf-8", errors="replace").strip()
    return value or None


def _is_mutating_command(args) -> bool:
    cmd = getattr(args, "command", "")
    if cmd in {
        "sync-studio-cli",
        "studio-cli-sha",
        "status",
        "list",
        "vllm-capabilities",
        "vllm-render",
        "omni-status",
        "omni-warm",
    }:
        return False
    if cmd == "verify":
        return bool(getattr(args, "fix_defaults", False))
    if cmd == "reconcile":
        return bool(getattr(args, "apply", False))
    if cmd == "repair-lanes":
        return bool(getattr(args, "apply", False))
    return cmd in {
        "init",
        "omni-install",
        "omni-stop",
        "mlx-launch-configure-vllm",
        "mlx-launch-stop",
        "mlx-launch-start",
        "load",
        "unload",
        "unload-all",
        "ensure",
        "offload-og",
        "sync-gateway",
        "assign-team",
        "ensemble",
        "vllm-set",
    }


def _enforce_studio_cli_parity(args):
    if os.environ.get("MLXCTL_ENFORCE_REMOTE_PARITY", "1").strip().lower() in {"0", "false", "no"}:
        return
    if args.local:
        return
    if not _is_mutating_command(args):
        return
    if _is_local_host():
        return

    local_path = Path(__file__).resolve()
    local_sha = _sha256_path(local_path)
    studio_host = _studio_ssh_target()
    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    remote_sha = _studio_cli_sha(studio_host, studio_cmd)
    if not remote_sha:
        raise SystemExit(
            "unable to read remote mlxctl hash; run:\n"
            "  ./platform/ops/scripts/mlxctl studio-cli-sha\n"
            "or disable parity gate temporarily with MLXCTL_ENFORCE_REMOTE_PARITY=0"
        )
    if local_sha != remote_sha:
        raise SystemExit(
            "mlxctl parity mismatch (local vs Studio). Refusing mutating command.\n"
            f"local:  {local_sha}  ({local_path})\n"
            f"studio: {remote_sha}  ({studio_cmd} on {studio_host})\n"
            "sync first:\n"
            "  ./platform/ops/scripts/mlxctl sync-studio-cli"
        )


def _registry_path():
    return Path(os.environ.get("MLX_REGISTRY_PATH", DEFAULT_REGISTRY))


def _hf_home():
    return Path(os.environ.get("HF_HOME", DEFAULT_HF_HOME))


@contextmanager
def _registry_lock(path: Path):
    lock_path = path.with_suffix(".lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("w") as lock_handle:
        if fcntl:
            fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX)
        yield
        if fcntl:
            fcntl.flock(lock_handle.fileno(), fcntl.LOCK_UN)


def _load_registry(path: Path):
    path.parent.mkdir(parents=True, exist_ok=True)
    if not path.exists():
        path.write_text(json.dumps({"version": 1, "models": {}}, indent=2))
    with _registry_lock(path):
        data = _loads_json_or_die(path.read_text(), context=f"registry file {path}", default="{}")
    data.setdefault("version", 1)
    data.setdefault("models", {})
    return data


def _port_for_model(model_id: str, data):
    entry = data.get("models", {}).get(model_id)
    if entry and entry.get("port"):
        return int(entry["port"])
    for slug, row in data.get("models", {}).items():
        if row.get("model_id") == model_id and row.get("port"):
            return int(row["port"])
    return PORT_MAP.get(model_id)


def _load_ensembles_doc(path: Path):
    if not path.exists():
        return {}
    handle = None
    ensembles = {}
    for raw in path.read_text().splitlines():
        line = raw.strip()
        match = re.match(r"- \*\*(opt-[^*]+)\*\*", line)
        if match:
            handle = match.group(1)
            ensembles.setdefault(handle, [])
            continue
        if not handle:
            continue
        if line.startswith("- Base:") or line.startswith("- Bases:"):
            models = re.findall(r"`([^`]+)`", line)
            if models:
                ensembles[handle].extend(models)
    return ensembles


def _write_registry(path: Path, data):
    tmp = path.with_suffix(".tmp")
    payload = json.dumps(data, indent=2)
    with _registry_lock(path):
        tmp.write_text(payload)
        tmp.replace(path)


def _slugify(text: str):
    text = text.lower().replace("/", "-")
    text = re.sub(r"[^a-z0-9-_]+", "-", text).strip("-")
    return text


def _is_quant_token(token: str) -> bool:
    if token in {
        "mxfp4",
        "mxfp8",
        "fp16",
        "fp8",
        "fp4",
        "int4",
        "int8",
        "int16",
        "bf16",
    }:
        return True
    if re.match(r"^q\\d+$", token):
        return True
    if token.endswith("bit"):
        return True
    return False


def _extract_param_token(tokens):
    for idx, token in enumerate(tokens):
        if token.endswith("b") and token[0].isdigit():
            if idx > 0 and tokens[idx - 1].isdigit():
                return idx - 1, idx, f"{tokens[idx - 1]}-{token}"
            return idx, idx, token
    return None


def _canonical_model_id(repo_id: str):
    _org, _sep, name = repo_id.partition("/")
    base = _slugify(name)
    if base.startswith("mlx-"):
        base = base[len("mlx-"):]
    base = base.replace("-mlx-", "-")
    if base.endswith("-mlx"):
        base = base[:-4]
    tokens = [t for t in base.split("-") if t]
    if not tokens:
        return "mlx-unknown"

    param_info = _extract_param_token(tokens)
    if not param_info:
        return f"mlx-{base}"

    param_start, param_end, param_token = param_info
    family_tokens = tokens[:param_start]
    remainder = tokens[param_end + 1 :]
    quant_tokens = [t for t in remainder if _is_quant_token(t)]
    other_tokens = [t for t in remainder if t not in quant_tokens]
    ordered = family_tokens + [param_token] + quant_tokens + other_tokens
    return "mlx-" + "-".join(ordered)


def _repo_from_dir(name: str):
    if not name.startswith("models--"):
        return None
    parts = name.replace("models--", "", 1).split("--", 1)
    if len(parts) != 2:
        return None
    return f"{parts[0]}/{parts[1]}"


def _latest_snapshot(model_dir: Path):
    snapshots = model_dir / "snapshots"
    if not snapshots.exists():
        return None
    candidates = list(snapshots.iterdir())
    if not candidates:
        return None
    return max(candidates, key=lambda p: p.stat().st_mtime)


def _guess_format(repo_id: str):
    return "gguf" if "gguf" in repo_id.lower() else "mlx"


def _find_entry(data, model_ref: str):
    models = data.get("models", {})
    if model_ref in models:
        return model_ref, models[model_ref]
    for slug, entry in models.items():
        if entry.get("repo_id") == model_ref:
            return slug, entry
    return None, None


def _is_preconverted(repo_id: str, override: Optional[str] = None):
    if override == "yes":
        return True
    if override == "no":
        return False
    org, _sep, _name = repo_id.partition("/")
    orgs = os.environ.get("MLX_PRECONVERTED_ORGS", "mlx-community,mlx,ml-explore").split(",")
    orgs = {o.strip().lower() for o in orgs if o.strip()}
    hints = os.environ.get("MLX_PRECONVERTED_HINTS", "mlx").split(",")
    hints = {h.strip().lower() for h in hints if h.strip()}
    repo_lower = repo_id.lower()
    return org.lower() in orgs or any(hint in repo_lower for hint in hints)


def _port_listening(port: int):
    try:
        result = subprocess.run(
            ["lsof", "-tiTCP:%d" % port, "-sTCP:LISTEN"],
            capture_output=True,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        raise SystemExit("lsof is required on the Studio to detect ports.")
    pids = [line for line in result.stdout.splitlines() if line.strip()]
    return pids


def _ps_snapshot():
    try:
        result = subprocess.run(
            ["ps", "-ax", "-o", "pid=,ppid=,command="],
            capture_output=True,
            text=True,
            check=False,
        )
    except FileNotFoundError:
        raise SystemExit("ps is required on the Studio to inspect processes.")
    rows = []
    for line in result.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        parts = line.split(None, 2)
        if len(parts) < 3:
            continue
        pid, ppid, cmd = parts
        rows.append((int(pid), int(ppid), cmd))
    return rows


def _mlx_pids_for_port(port: int):
    pids = []
    for pid, _ppid, _cmd, _family in _mlx_processes_for_port(port):
        pids.append(pid)
    return pids


def _mlx_process_family(cmd: str) -> Optional[str]:
    try:
        parts = shlex.split(cmd)
    except ValueError:
        parts = []
    for idx, token in enumerate(parts):
        if idx + 1 >= len(parts):
            continue
        name = Path(token).name
        if name in {"vllm", "vllm.py"} and parts[idx + 1] == "serve":
            return "vllm-metal"
    if " vllm serve " in f" {cmd} ":
        return "vllm-metal"
    if "mlx_lm.server" in cmd:
        return "mlx_lm.server"
    if "mlx-openai-server" in cmd or "mlx_openai_server" in cmd:
        return "mlx-openai-server"
    return None


def _mlx_processes_for_port(port: int):
    port_token = re.compile(rf"--port(?:=|\s+){port}\b")
    rows = []
    for pid, ppid, cmd in _ps_snapshot():
        family = _mlx_process_family(cmd)
        if not family:
            continue
        if not port_token.search(cmd):
            continue
        rows.append((pid, ppid, cmd, family))
    return rows


def _mlx_runtime_command_for_port(port: int) -> Optional[str]:
    rows = _mlx_processes_for_port(port)
    if not rows:
        return None
    # Prefer vllm-metal when multiple runtime families appear.
    rank = {"vllm-metal": 0, "mlx_lm.server": 1, "mlx-openai-server": 2}
    rows.sort(key=lambda row: (rank.get(row[3], 9), row[0]))
    return rows[0][2]


def _runtime_model_path_from_command(command: str) -> Optional[str]:
    try:
        parts = shlex.split(command)
    except ValueError:
        parts = []
    if parts:
        for idx, token in enumerate(parts):
            if token == "serve" and idx + 1 < len(parts):
                model_token = parts[idx + 1]
                if not model_token.startswith("-"):
                    return model_token
    return _command_arg_value(command, "--model") or _command_arg_value(command, "--model-path")


def _include_children(pids):
    snapshot = _ps_snapshot()
    by_ppid = {}
    for pid, ppid, cmd in snapshot:
        by_ppid.setdefault(ppid, []).append((pid, cmd))
    expanded = set(pids)
    queue = list(pids)
    while queue:
        current = queue.pop()
        for child_pid, _cmd in by_ppid.get(current, []):
            if child_pid not in expanded:
                expanded.add(child_pid)
                queue.append(child_pid)
    return sorted(expanded)


def _kill_pids(pids, timeout: int = 10):
    if not pids:
        return
    for pid in pids:
        subprocess.run(["kill", str(pid)], check=False)
    deadline = time.time() + timeout
    remaining = set(pids)
    while remaining and time.time() < deadline:
        live = set(pid for pid, _ppid, _cmd in _ps_snapshot())
        remaining = remaining.intersection(live)
        if remaining:
            time.sleep(0.5)
    if remaining:
        for pid in remaining:
            subprocess.run(["kill", "-9", str(pid)], check=False)


def _stop_mlx_for_port(port: int):
    pids = _mlx_pids_for_port(port)
    if not pids:
        return
    tree = _include_children(pids)
    _kill_pids(tree)


def _launchd_loaded(label: str):
    if sys.platform != "darwin":
        return False
    result = subprocess.run(
        ["launchctl", "print", f"system/{label}"],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.returncode == 0


def _parse_launchctl_print_disabled(text: str) -> dict:
    states = {}
    for raw in text.splitlines():
        line = raw.strip()
        if "=>" not in line:
            continue
        left, right = line.split("=>", 1)
        label = left.strip().strip(",").strip('"')
        if not label:
            continue
        value = right.strip().strip(",").lower()
        if value in {"true", "1", "yes", "disabled"}:
            states[label] = True
        elif value in {"false", "0", "no", "enabled"}:
            states[label] = False
    return states


def _launchctl_disabled_map() -> dict:
    if sys.platform != "darwin":
        return {}
    result = subprocess.run(
        ["launchctl", "print-disabled", "system"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return {}
    return _parse_launchctl_print_disabled(result.stdout or "")


def _lane_label(port: int) -> str:
    return f"{os.environ.get('MLX_LANE_LABEL_PREFIX', DEFAULT_MLX_LANE_LABEL_PREFIX)}.{int(port)}"


def _lane_launchd_state(port: int, disabled_map: Optional[dict] = None) -> dict:
    label = _lane_label(port)
    if sys.platform != "darwin":
        return {"label": label, "loaded": None, "disabled": None}
    if disabled_map is None:
        disabled_map = _launchctl_disabled_map()
    return {
        "label": label,
        "loaded": _launchd_loaded(label),
        "disabled": disabled_map.get(label),
    }


def _maybe_stop_launchd(label: str):
    if not _launchd_loaded(label):
        return
    if os.geteuid() != 0:
        print(f"launchd job {label} is loaded; stop it with:")
        print(f"sudo launchctl bootout system/{label}")
        return
    subprocess.run(["launchctl", "bootout", f"system/{label}"], check=False)


def _prompt_yes_no(message: str):
    reply = input(f"{message} [y/N]: ").strip().lower()
    return reply in {"y", "yes"}


def _model_on_port(data, port: int):
    for slug, entry in data["models"].items():
        if entry.get("port") == port:
            return slug, entry
    return None, None


def _wait_for_port(port: int, timeout: int = 60):
    start = time.time()
    while time.time() - start < timeout:
        if _port_listening(port) or _mlx_pids_for_port(port):
            return True
        time.sleep(1)
    return False


def _models_endpoint_ok(port: int, timeout: int = 2) -> bool:
    try:
        req = urlrequest.Request(f"http://127.0.0.1:{port}/v1/models", method="GET")
        with urlrequest.urlopen(req, timeout=timeout) as resp:
            code = getattr(resp, "status", 200)
            return 200 <= int(code) < 300
    except Exception:
        return False


def _available_port(data, preferred_range):
    assigned = {entry.get("port") for entry in data.get("models", {}).values() if entry.get("port")}
    for port in preferred_range:
        if port in assigned:
            continue
        if _port_listening(port) or _mlx_pids_for_port(port):
            continue
        return port
    return None


def cmd_init(_args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    models = data["models"]

    hub = _hf_home() / "hub"
    if not hub.exists():
        raise SystemExit(f"HF hub directory not found: {hub}")

    added = 0
    for model_dir in hub.iterdir():
        repo_id = _repo_from_dir(model_dir.name)
        if not repo_id:
            continue
        slug = _canonical_model_id(repo_id)
        if slug in models:
            _ensure_defaults(models[slug])
            continue
        snapshot = _latest_snapshot(model_dir)
        if not snapshot:
            continue
        models[slug] = {
            "repo_id": repo_id,
            "model_id": slug,
            "cache_path": str(snapshot),
            "format": _guess_format(repo_id),
            "port": None,
        }
        _ensure_defaults(models[slug])
        added += 1

    _write_registry(registry_path, data)
    print(f"registry initialized: {registry_path} (added {added})")


def cmd_list(_args):
    data = _load_registry(_registry_path())
    for slug, entry in sorted(data["models"].items()):
        port = entry.get("port")
        repo_id = entry.get("repo_id")
        ctx = entry.get("context_length") or "-"
        max_out = entry.get("max_output_tokens") or "-"
        print(f"{slug}\t{repo_id}\t{port if port else '-'}\t{ctx}\t{max_out}")


def cmd_status(_args):
    data = _load_registry(_registry_path())
    port_map = {entry.get("port"): slug for slug, entry in data["models"].items() if entry.get("port")}
    disabled_map = _launchctl_disabled_map() if getattr(_args, "checks", False) else {}
    rows = []
    for port in PORT_RANGE:
        pids = _port_listening(port)
        proc_pids = _mlx_pids_for_port(port)
        slug = port_map.get(port)
        listener_visible = bool(pids)
        status = "listening" if listener_visible else ("running" if proc_pids else "idle")
        pid_str = ",".join(pids if pids else [str(pid) for pid in proc_pids]) if (pids or proc_pids) else "-"
        model_str = slug if slug else "-"
        runtime_cmd = _mlx_runtime_command_for_port(port)
        runtime_family = "-"
        runtime_model = "-"
        if runtime_cmd:
            runtime_family = _mlx_process_family(runtime_cmd) or "-"
            runtime_model = _runtime_model_path_from_command(runtime_cmd) or "-"
        row = {
            "port": port,
            "status": status,
            "pids": pid_str,
            "registry_model": model_str,
            "runtime_family": runtime_family,
            "runtime_model_path": runtime_model,
            "listener_visible": listener_visible,
        }
        if getattr(_args, "checks", False):
            row["http_models_ok"] = _models_endpoint_ok(port) if status != "idle" else None
        if getattr(_args, "checks", False) and port in TEAM_RANGE:
            lane_state = _lane_launchd_state(port, disabled_map=disabled_map)
            row["launchd_label"] = lane_state["label"]
            row["launchd_loaded"] = lane_state["loaded"]
            row["launchd_disabled"] = lane_state["disabled"]
        rows.append(row)
        if not getattr(_args, "json", False) or getattr(_args, "table", False):
            print(f"{port}\t{status}\t{pid_str}\t{model_str}")

    if getattr(_args, "checks", False):
        if not getattr(_args, "json", False) or getattr(_args, "table", False):
            print("")
            print("# runtime checks")
            for row in rows:
                if row["status"] == "idle":
                    continue
                mismatch = ""
                if row["registry_model"] != "-" and row["runtime_model_path"] == "-":
                    mismatch = "missing-runtime-model"
                print(
                    f"{row['port']}\tfamily={row['runtime_family']}\truntime_model={row['runtime_model_path']}"
                    + (f"\thttp_models_ok={row.get('http_models_ok')}" if "http_models_ok" in row else "")
                    + (f"\t{mismatch}" if mismatch else "")
                    + (
                        f"\tlaunchd_loaded={row.get('launchd_loaded')}\tlaunchd_disabled={row.get('launchd_disabled')}"
                        if row["port"] in TEAM_RANGE
                        else ""
                    )
                )

    if getattr(_args, "json", False):
        print(json.dumps({"ports": rows}, indent=2))


def _infer_context_length(entry: dict) -> Optional[int]:
    cache_path = entry.get("cache_path")
    if not cache_path:
        return None
    path = Path(cache_path)
    candidates = [path / "config.json", path.parent / "config.json"]
    for cfg in candidates:
        if not cfg.exists():
            continue
        try:
            data = json.loads(cfg.read_text())
        except Exception:
            continue
        for key in ("max_position_embeddings", "model_max_length", "n_positions", "max_sequence_length"):
            val = data.get(key)
            if isinstance(val, int) and val > 0 and val < 1_000_000:
                return val
    return None


def _entry_identity_text(entry: dict) -> str:
    parts = [
        str(entry.get("model_id") or ""),
        str(entry.get("repo_id") or ""),
        str(entry.get("cache_path") or ""),
    ]
    return " ".join(parts).lower()


def _is_gpt_oss_entry(entry: dict) -> bool:
    return "gpt-oss" in _entry_identity_text(entry)


def _is_qwen3_entry(entry: dict) -> bool:
    text = _entry_identity_text(entry)
    return "qwen3" in text or "qwen-3" in text


def _resolve_gpt_oss_chat_template(entry: dict) -> Optional[str]:
    text = _entry_identity_text(entry)
    tokens = {tok for tok in re.split(r"[^a-z0-9]+", text) if tok}
    template_dir = Path(os.environ.get("MLX_TEMPLATE_DIR", DEFAULT_TEMPLATE_DIR))
    if not template_dir.exists():
        return None
    candidates = []
    if "120b" in tokens:
        candidates.append("gpt-oss-120b-chat_template.jinja")
    if "20b" in tokens:
        candidates.append("gpt-oss-20b-chat_template.jinja")
    candidates.extend(
        [
            "gpt-oss-chat_template.jinja",
            "gpt-oss-120b-chat_template.jinja",
            "gpt-oss-20b-chat_template.jinja",
        ]
    )
    for name in candidates:
        candidate = template_dir / name
        if candidate.exists():
            return str(candidate)
    return None


def _resolve_local_chat_template(entry: dict) -> Optional[str]:
    cache_path = entry.get("cache_path")
    if not cache_path:
        return None
    path = Path(cache_path)
    candidates = [path / "chat_template.jinja", path.parent / "chat_template.jinja"]
    for candidate in candidates:
        if candidate.exists():
            return str(candidate)
    return None


def _ensure_defaults(entry: dict):
    changed = False
    if not entry.get("context_length"):
        inferred = _infer_context_length(entry)
        entry["context_length"] = inferred or DEFAULT_CONTEXT_LENGTH
        changed = True
    if not entry.get("max_output_tokens"):
        entry["max_output_tokens"] = min(DEFAULT_MAX_OUTPUT_TOKENS, int(entry["context_length"]))
        changed = True

    # Family-safe defaults: GPT-OSS models require Harmony parsing/template.
    if _is_gpt_oss_entry(entry):
        if not entry.get("tool_call_parser"):
            entry["tool_call_parser"] = "harmony"
            changed = True
        if not entry.get("reasoning_parser"):
            entry["reasoning_parser"] = "harmony"
            changed = True
        template = _resolve_gpt_oss_chat_template(entry)
        current_template = entry.get("chat_template")
        if template and not current_template:
            entry["chat_template"] = template
            changed = True
        elif template and current_template:
            tokens = {tok for tok in re.split(r"[^a-z0-9]+", _entry_identity_text(entry)) if tok}
            current_name = Path(current_template).name
            if ("120b" in tokens and "20b" in current_name) or ("20b" in tokens and "120b" in current_name):
                entry["chat_template"] = template
                changed = True
    elif _is_qwen3_entry(entry):
        if not entry.get("tool_call_parser"):
            entry["tool_call_parser"] = "qwen3"
            changed = True
        if not entry.get("reasoning_parser"):
            entry["reasoning_parser"] = "qwen3"
            changed = True
        if not entry.get("chat_template"):
            local_template = _resolve_local_chat_template(entry)
            if local_template:
                entry["chat_template"] = local_template
                changed = True

    vllm = _entry_vllm_config(entry)
    if not vllm:
        vllm = {}
        entry["vllm"] = vllm
        changed = True
    if not vllm.get("profile"):
        vllm["profile"] = _default_vllm_profile(entry)
        changed = True
    if not vllm.get("tool_choice_mode"):
        vllm["tool_choice_mode"] = _default_vllm_tool_choice_mode(entry)
        changed = True
    if not vllm.get("max_model_len"):
        vllm["max_model_len"] = _default_vllm_max_model_len(entry)
        changed = True
    if not vllm.get("memory_fraction"):
        vllm["memory_fraction"] = _default_vllm_memory_fraction(entry)
        changed = True
    if "async_scheduling" not in vllm:
        vllm["async_scheduling"] = _default_vllm_async_scheduling(entry)
        changed = True
    if _default_vllm_profile(entry) == "qwen3_main":
        if not vllm.get("tool_call_parser"):
            vllm["tool_call_parser"] = "qwen3"
            changed = True
        if not vllm.get("reasoning_parser"):
            vllm["reasoning_parser"] = "qwen3"
            changed = True
    return changed


def _raw_harmony_tags_detected(port: int, model_name: str) -> bool:
    payload = {
        "model": model_name,
        "messages": [{"role": "user", "content": "Return one short sentence about oranges."}],
        "max_tokens": 128,
    }
    try:
        req = urlrequest.Request(
            f"http://127.0.0.1:{port}/v1/chat/completions",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urlrequest.urlopen(req, timeout=20) as resp:
            body = resp.read().decode("utf-8")
        data = json.loads(body)
    except Exception:
        return False
    content = data.get("choices", [{}])[0].get("message", {}).get("content")
    return isinstance(content, str) and "<|channel|>" in content


def _raw_qwen3_tags_detected(port: int, model_name: str) -> bool:
    payload = {
        "model": model_name,
        "messages": [{"role": "user", "content": "Return one short sentence about apples."}],
        "max_tokens": 96,
    }
    try:
        req = urlrequest.Request(
            f"http://127.0.0.1:{port}/v1/chat/completions",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urlrequest.urlopen(req, timeout=20) as resp:
            body = resp.read().decode("utf-8")
        data = json.loads(body)
    except Exception:
        return False
    content = data.get("choices", [{}])[0].get("message", {}).get("content")
    if not isinstance(content, str):
        return False
    return any(marker in content for marker in ("<think>", "<tool_call>", "<|im_start|>", "<|im_end|>"))


def _mlx_command_for_port(port: int) -> Optional[str]:
    return _mlx_runtime_command_for_port(port)


def _command_arg_value(command: str, flag: str) -> Optional[str]:
    try:
        parts = shlex.split(command)
    except ValueError:
        return None
    for idx, token in enumerate(parts):
        if token == flag and idx + 1 < len(parts):
            return parts[idx + 1]
        if token.startswith(flag + "="):
            return token.split("=", 1)[1]
    return None


def _coerce_bool(value, default: bool = False) -> bool:
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "y", "on"}:
            return True
        if lowered in {"0", "false", "no", "n", "off"}:
            return False
    return default


def _entry_vllm_config(entry: dict) -> dict:
    cfg = entry.get("vllm")
    return cfg if isinstance(cfg, dict) else {}


def _entry_vllm_value(entry: dict, key: str, legacy_key: Optional[str] = None):
    cfg = _entry_vllm_config(entry)
    if key in cfg:
        return cfg.get(key)
    if legacy_key and legacy_key in entry:
        return entry.get(legacy_key)
    return None


def _default_vllm_profile(entry: dict) -> str:
    explicit = _entry_vllm_value(entry, "profile")
    if isinstance(explicit, str) and explicit.strip():
        return explicit.strip()
    text = _entry_identity_text(entry)
    if "qwen3-next-80b" in text:
        return "qwen3_main"
    if "gpt-oss" in text:
        return "gpt_oss_lane"
    return "generic"


def _default_vllm_tool_choice_mode(entry: dict) -> str:
    explicit = _entry_vllm_value(entry, "tool_choice_mode")
    if isinstance(explicit, str):
        lowered = explicit.strip().lower()
        if lowered in {"none", "auto"}:
            return lowered
    profile = _default_vllm_profile(entry)
    if profile == "qwen3_main":
        return "auto"
    return "none"


def _default_vllm_tool_parser(entry: dict) -> Optional[str]:
    explicit = _entry_vllm_value(entry, "tool_call_parser", "tool_call_parser")
    if isinstance(explicit, str) and explicit.strip():
        return explicit.strip()
    if _default_vllm_profile(entry) == "qwen3_main":
        return "qwen3"
    return None


def _default_vllm_reasoning_parser(entry: dict) -> Optional[str]:
    explicit = _entry_vllm_value(entry, "reasoning_parser", "reasoning_parser")
    if isinstance(explicit, str) and explicit.strip():
        return explicit.strip()
    if _default_vllm_profile(entry) == "qwen3_main":
        return "qwen3"
    return None


def _default_vllm_max_model_len(entry: dict) -> int:
    explicit = _entry_vllm_value(entry, "max_model_len", "vllm_max_model_len")
    if isinstance(explicit, str) and explicit.strip().isdigit():
        explicit = int(explicit.strip())
    if isinstance(explicit, int) and explicit > 0:
        return explicit
    text = _entry_identity_text(entry)
    if "qwen3-next-80b" in text:
        return 65536
    if "gpt-oss-120b" in text:
        return 65536
    if "gpt-oss-20b" in text:
        return 32768
    context = entry.get("context_length")
    if isinstance(context, int) and context > 0:
        return min(context, 65536)
    return 65536


def _default_vllm_memory_fraction(entry: dict) -> str:
    explicit = _entry_vllm_value(entry, "memory_fraction", "vllm_memory_fraction")
    if explicit is None:
        return "auto"
    value = str(explicit).strip().lower()
    if not value:
        return "auto"
    return value


def _validated_vllm_memory_fraction(entry: dict) -> str:
    value = _default_vllm_memory_fraction(entry).strip().lower()
    if value == "auto":
        return value
    try:
        float(value)
    except ValueError:
        raise SystemExit(
            f"{_lane_handle_for_entry(entry)} memory_fraction={value!r} unsupported for the "
            "MLX-managed vllm-metal path in this commit; use 'auto'"
        )
    raise SystemExit(
        f"{_lane_handle_for_entry(entry)} memory_fraction={value!r} is invalid while paged "
        "attention remains disabled; use 'auto'"
    )


def _default_vllm_async_scheduling(entry: dict) -> bool:
    explicit = _entry_vllm_value(entry, "async_scheduling", "vllm_async_scheduling")
    return _coerce_bool(explicit, default=False)


def _detect_vllm_capabilities(vllm_bin: Optional[str] = None) -> dict:
    selected_bin = vllm_bin or os.environ.get("MLX_VLLM_BIN", DEFAULT_VLLM_BIN)
    if not selected_bin:
        selected_bin = DEFAULT_VLLM_BIN
    argv = [selected_bin]
    if not Path(selected_bin).exists():
        fallback = shutil.which("vllm")
        if not fallback:
            raise SystemExit("vllm not found; set MLX_VLLM_BIN or install vllm.")
        argv = [fallback]
    timeout_seconds = _parse_int_arg(
        os.environ.get("MLX_VLLM_HELP_TIMEOUT_SECONDS", "20"),
        arg_name="MLX_VLLM_HELP_TIMEOUT_SECONDS",
    )
    if timeout_seconds <= 0:
        timeout_seconds = 20
    try:
        result = subprocess.run(
            argv + ["serve", "--help=all"],
            capture_output=True,
            text=True,
            check=False,
            timeout=timeout_seconds,
        )
    except subprocess.TimeoutExpired:
        raise SystemExit(
            f"vllm capability probe timed out after {timeout_seconds}s; "
            "increase MLX_VLLM_HELP_TIMEOUT_SECONDS if needed"
        )
    text = (result.stdout or "") + "\n" + (result.stderr or "")
    if not any(flag in text for flag in ("--host", "--port", "--served-model-name", "--model")):
        raise SystemExit(
            "vllm capability probe returned unusable help output; "
            "verify MLX_VLLM_BIN points to a working `vllm` binary"
        )
    parser_choices = []
    match = re.search(r"--tool-call-parser\s+\{([^}]*)\}", text)
    if match:
        parser_choices = [item.strip() for item in match.group(1).split(",") if item.strip()]
    return {
        "vllm_bin": argv[0],
        "supports_auto_tool_choice": "--enable-auto-tool-choice" in text,
        "supports_tool_call_parser": "--tool-call-parser" in text,
        "supports_reasoning_parser": "--reasoning-parser" in text,
        "tool_call_parsers": parser_choices,
    }


def _resolve_tool_call_parser(logical: str, capabilities: dict) -> Optional[str]:
    if logical != "qwen3":
        return logical
    parser_choices = set(capabilities.get("tool_call_parsers") or [])
    for candidate in ("qwen3_xml", "qwen3_coder", "qwen3"):
        if candidate in parser_choices:
            return candidate
    return None


def _compile_vllm_launch(entry: dict, port: int, host: str, capabilities: dict, *, validate: bool = True) -> dict:
    model_path = entry.get("cache_path")
    if not model_path:
        raise SystemExit("registry entry missing cache_path for vllm launch")
    served_model_name = entry.get("served_model_name") or entry.get("model_id")
    if not served_model_name:
        raise SystemExit("registry entry missing model_id/served_model_name for vllm launch")
    entry = dict(entry)
    entry.setdefault("served_model_name", served_model_name)
    entry.setdefault("port", port)
    lane_api_key = ""
    if validate:
        _, lane_api_key = _validated_lane_api_key(entry)
    else:
        _, lane_api_key = _resolve_lane_api_key(entry)
    memory_fraction = _validated_vllm_memory_fraction(entry) if validate else _default_vllm_memory_fraction(entry).strip().lower()

    tool_choice_mode = _default_vllm_tool_choice_mode(entry)
    if tool_choice_mode not in {"none", "auto"}:
        raise SystemExit(f"unsupported vllm tool_choice_mode={tool_choice_mode!r} for {served_model_name}")

    argv = [
        capabilities["vllm_bin"],
        "serve",
        model_path,
        "--served-model-name",
        served_model_name,
        "--host",
        host,
        "--port",
        str(port),
        "--max-model-len",
        str(_default_vllm_max_model_len(entry)),
    ]
    if lane_api_key:
        argv += ["--api-key", lane_api_key]
    if _default_vllm_async_scheduling(entry):
        argv += ["--async-scheduling"]
    else:
        argv += ["--no-async-scheduling"]

    parser_choices = set(capabilities.get("tool_call_parsers") or [])
    parser_logical = _default_vllm_tool_parser(entry)
    parser_resolved = None
    if tool_choice_mode == "auto":
        if validate and not capabilities.get("supports_auto_tool_choice"):
            raise SystemExit(
                f"{served_model_name} requires tool_choice_mode=auto, but vLLM does not support --enable-auto-tool-choice"
            )
        argv += ["--enable-auto-tool-choice"]
        if validate and not capabilities.get("supports_tool_call_parser"):
            raise SystemExit(f"{served_model_name} requires tool_choice_mode=auto, but vLLM lacks --tool-call-parser")
        if not parser_logical:
            raise SystemExit(f"{served_model_name} requires tool_choice_mode=auto but tool_call_parser is unset")
        parser_resolved = _resolve_tool_call_parser(parser_logical, capabilities)
        if not parser_resolved:
            choices = ", ".join(sorted(parser_choices)) if parser_choices else "(none reported)"
            raise SystemExit(
                f"{served_model_name} tool_call_parser={parser_logical!r} unsupported by current vLLM parser set: {choices}"
            )
        argv += ["--tool-call-parser", parser_resolved]

    reasoning_parser = _default_vllm_reasoning_parser(entry)
    explicit_reasoning = "reasoning_parser" in _entry_vllm_config(entry)
    if reasoning_parser and capabilities.get("supports_reasoning_parser") and (tool_choice_mode == "auto" or explicit_reasoning):
        argv += ["--reasoning-parser", reasoning_parser]

    env = {
        "VLLM_METAL_MEMORY_FRACTION": memory_fraction,
    }
    return {
        "argv": argv,
        "env": env,
        "tool_choice_mode": tool_choice_mode,
        "tool_call_parser_logical": parser_logical,
        "tool_call_parser_resolved": parser_resolved,
        "reasoning_parser": reasoning_parser,
        "profile": _default_vllm_profile(entry),
        "max_model_len": _default_vllm_max_model_len(entry),
        "async_scheduling": _default_vllm_async_scheduling(entry),
    }


def _default_startup_timeout(entry: dict) -> int:
    explicit = entry.get("startup_timeout_seconds")
    if explicit is None:
        explicit = entry.get("vllm_startup_timeout_seconds")
    if isinstance(explicit, int) and explicit > 0:
        return explicit
    if isinstance(explicit, str) and explicit.strip().isdigit():
        val = int(explicit.strip())
        if val > 0:
            return val

    text = _entry_identity_text(entry)
    if "gpt-oss-120b" in text:
        return 900
    if "qwen3-next-80b" in text:
        return 600
    if "gpt-oss-20b" in text:
        return 300
    return 180


def _render_vllm_launch_start_script() -> str:
    return """#!/bin/zsh
set -euo pipefail
cd /opt/mlx-launch

export PATH="/opt/homebrew/bin:/Users/thestudio/.local/bin:/Users/thestudio/.venv-vllm-metal/bin:/usr/bin:/bin:/usr/sbin:/sbin"

REGISTRY_PATH="${MLX_REGISTRY_PATH:-/Users/thestudio/models/hf/hub/registry.json}"
HOST="${MLX_BIND_HOST:-0.0.0.0}"
LOG_DIR="${MLX_VLLM_LOG_DIR:-/Users/thestudio}"
VLLM_BIN="${MLX_VLLM_BIN:-/Users/thestudio/.venv-vllm-metal/bin/vllm}"

if [[ ! -x "$VLLM_BIN" ]]; then
  echo "$(/bin/date -u +%Y-%m-%dT%H:%M:%SZ) missing vllm binary: $VLLM_BIN" >> /opt/mlx-launch/logs/server.log
  exit 2
fi

ROWS=$(python3 - "$REGISTRY_PATH" <<'PY'
import json
import re
import sys
from pathlib import Path

reg = Path(sys.argv[1])
if not reg.exists():
    raise SystemExit(0)

try:
    data = json.loads(reg.read_text() or "{}")
except Exception:
    raise SystemExit(0)

def identity(entry, slug):
    parts = [str(entry.get("model_id") or slug), str(entry.get("repo_id") or ""), str(entry.get("cache_path") or "")]
    return " ".join(parts).lower()

def default_max_model_len(entry, slug):
    val = entry.get("vllm_max_model_len")
    if isinstance(val, int) and val > 0:
        return val
    text = identity(entry, slug)
    if "qwen3-next-80b" in text:
        return 65536
    if "gpt-oss-120b" in text:
        return 65536
    if "gpt-oss-20b" in text:
        return 32768
    context = entry.get("context_length")
    if isinstance(context, int) and context > 0:
        return min(context, 65536)
    return 65536

def default_memory_fraction(entry, slug):
    explicit = entry.get("vllm_memory_fraction")
    if explicit is not None:
        value = str(explicit).strip().lower()
        return value or "auto"
    return "auto"

def as_bool(value, default=False):
    if value is None:
        return default
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in {"1", "true", "yes", "y", "on"}:
            return True
        if lowered in {"0", "false", "no", "n", "off"}:
            return False
    return default

rows = []
for slug, entry in (data.get("models") or {}).items():
    port = entry.get("port")
    try:
        port = int(port)
    except Exception:
        continue
    if port < 8100 or port > 8119:
        continue

    model_path = entry.get("cache_path")
    if not model_path:
        continue
    model_path_obj = Path(model_path)
    if not model_path_obj.exists():
        continue

    served_model_name = entry.get("model_id") or slug
    max_model_len = default_max_model_len(entry, slug)
    memory_fraction = default_memory_fraction(entry, slug)
    async_enabled = as_bool(entry.get("vllm_async_scheduling"), default=False)

    rows.append((served_model_name, str(port), str(model_path_obj), str(max_model_len), memory_fraction, "1" if async_enabled else "0"))

rows.sort(key=lambda r: int(r[1]))
for row in rows:
    print("\\x1f".join(row))
PY
)

if [[ -z "${ROWS}" ]]; then
  echo "$(/bin/date -u +%Y-%m-%dT%H:%M:%SZ) no assigned team-lane models in registry; exiting" >> /opt/mlx-launch/logs/server.log
  exit 0
fi

mkdir -p "$LOG_DIR"
{
  echo "$(/bin/date -u +%Y-%m-%dT%H:%M:%SZ) launching team lanes via vllm-metal:"
  echo "$ROWS"
} >> /opt/mlx-launch/logs/server.log

typeset -a pids
while IFS=$'\\x1f' read -r name port path max_len mem_frac async_enabled; do
  [[ -z "${port}" ]] && continue
  cmd=("$VLLM_BIN" serve "$path" --served-model-name "$name" --host "$HOST" --port "$port" --max-model-len "$max_len")
  if [[ "$async_enabled" == "1" ]]; then
    cmd+=(--async-scheduling)
  else
    cmd+=(--no-async-scheduling)
  fi
  (
    export VLLM_METAL_MEMORY_FRACTION="$mem_frac"
    exec "${cmd[@]}"
  ) > "${LOG_DIR}/vllm-${port}.log" 2>&1 &
  pids+=($!)
  echo "$(/bin/date -u +%Y-%m-%dT%H:%M:%SZ) started $name on $port via vllm-metal (pid $!, max_len=$max_len, mem_frac=$mem_frac, async=$async_enabled)" >> /opt/mlx-launch/logs/server.log
  /bin/sleep 1
done <<< "$ROWS"

cleanup() {
  for pid in "${pids[@]:-}"; do
    kill "$pid" >/dev/null 2>&1 || true
  done
}
trap cleanup INT TERM
wait
"""


def _download_and_register(data, model_ref: str):
    try:
        from huggingface_hub import snapshot_download
    except ImportError as exc:
        raise SystemExit("huggingface_hub is required for downloads. Install it first.") from exc

    cache_dir = _hf_home()
    repo_id = model_ref
    snapshot = snapshot_download(repo_id, cache_dir=str(cache_dir))
    slug = _canonical_model_id(repo_id)
    data["models"][slug] = {
        "repo_id": repo_id,
        "model_id": slug,
        "cache_path": str(snapshot),
        "format": _guess_format(repo_id),
        "port": None,
    }
    return slug, data["models"][slug]


def _run_convert(repo_id: str, src_path: Path, dest_path: Path):
    cmd_tmpl = os.environ.get("MLX_CONVERT_CMD", DEFAULT_CONVERT_CMD)
    cmd = cmd_tmpl.format(repo=repo_id, src=src_path, dest=dest_path)
    argv = shlex.split(cmd)
    if not argv:
        raise SystemExit("MLX_CONVERT_CMD is empty")
    dest_path.mkdir(parents=True, exist_ok=True)
    result = subprocess.run(argv, check=False)
    if result.returncode != 0:
        raise SystemExit(f"conversion failed (exit {result.returncode})")


def _ensure_model(data, model_ref: str, name: Optional[str], convert_mode: str, preconverted: Optional[str]):
    slug, entry = _find_entry(data, model_ref)
    if entry:
        return slug, entry, False

    try:
        from huggingface_hub import snapshot_download
    except ImportError as exc:
        raise SystemExit("huggingface_hub is required for downloads. Install it first.") from exc

    cache_dir = _hf_home()
    repo_id = model_ref
    snapshot = snapshot_download(repo_id, cache_dir=str(cache_dir))
    slug = name or _canonical_model_id(repo_id)

    preconverted = _is_preconverted(repo_id, preconverted)
    do_convert = convert_mode == "force" or (convert_mode == "auto" and not preconverted)
    if convert_mode == "skip":
        do_convert = False

    repo_root = Path(snapshot).parent.parent
    entry = {
        "repo_id": repo_id,
        "model_id": slug,
        "cache_path": str(snapshot),
        "format": _guess_format(repo_id),
        "port": None,
    }

    if do_convert:
        hub = _hf_home() / "hub"
        dest = hub / f"converted--{slug}"
        if not dest.exists() or not any(dest.iterdir()):
            _run_convert(repo_id, Path(snapshot), dest)
        entry["og_path"] = str(repo_root)
        entry["cache_path"] = str(dest)
        entry["format"] = "mlx"

    data["models"][slug] = entry
    return slug, entry, do_convert


def _launch_server(entry, port: int):
    model_path = entry["cache_path"]
    cmd = os.environ.get("MLX_LAUNCH_CMD")
    backend = os.environ.get("MLX_BACKEND", "vllm-metal").strip()
    if cmd:
        argv = cmd.split()
        proc_env = None
    elif backend in {"vllm-metal", "vllm", "vllm_metal"}:
        capabilities = _detect_vllm_capabilities()
        compiled = _compile_vllm_launch(entry, port, "0.0.0.0", capabilities, validate=True)
        argv = compiled["argv"]
        proc_env = os.environ.copy()
        mem_fraction = (compiled.get("env", {}) or {}).get("VLLM_METAL_MEMORY_FRACTION", "").strip()
        if mem_fraction:
            proc_env["VLLM_METAL_MEMORY_FRACTION"] = mem_fraction
    elif backend == "mlx-openai-server":
        if shutil.which("mlx-openai-server"):
            argv = ["mlx-openai-server", "launch"]
        elif shutil.which("uv"):
            argv = ["uv", "run", "--project", "/opt/mlx-launch", "mlx-openai-server", "launch"]
        elif Path("/opt/homebrew/bin/uv").exists():
            argv = ["/opt/homebrew/bin/uv", "run", "--project", "/opt/mlx-launch", "mlx-openai-server", "launch"]
        else:
            raise SystemExit("mlx-openai-server not found; set MLX_LAUNCH_CMD or install it.")

        argv += [
            "--model-path",
            model_path,
            "--model-type",
            "lm",
            "--trust-remote-code",
            "--host",
            "0.0.0.0",
            "--port",
            str(port),
        ]

        tool_call_parser = entry.get("tool_call_parser") or os.environ.get("MLX_TOOL_CALL_PARSER")
        if tool_call_parser:
            argv += ["--tool-call-parser", tool_call_parser]

        reasoning_parser = entry.get("reasoning_parser") or os.environ.get("MLX_REASONING_PARSER")
        if reasoning_parser:
            argv += ["--reasoning-parser", reasoning_parser]

        chat_template = entry.get("chat_template") or os.environ.get("MLX_CHAT_TEMPLATE")
        if chat_template:
            argv += ["--chat-template-file", chat_template]
        proc_env = None
    else:
        mlx_lm_bin = os.environ.get("MLX_LM_SERVER_BIN", "/opt/mlx-launch/.venv/bin/mlx_lm.server")
        if Path(mlx_lm_bin).exists():
            argv = [mlx_lm_bin]
        elif shutil.which("mlx_lm.server"):
            argv = ["mlx_lm.server"]
        else:
            raise SystemExit("mlx_lm.server not found; set MLX_LM_SERVER_BIN or MLX_LAUNCH_CMD.")

        argv += [
            "--host",
            "0.0.0.0",
            "--port",
            str(port),
            "--model",
            model_path,
            "--trust-remote-code",
        ]

        chat_template = entry.get("chat_template") or os.environ.get("MLX_CHAT_TEMPLATE")
        if chat_template:
            argv += ["--chat-template", chat_template]
        else:
            argv += ["--use-default-chat-template"]

        chat_template_args = entry.get("chat_template_args")
        if not chat_template_args and _is_gpt_oss_entry(entry):
            chat_template_args = {"enable_thinking": False, "reasoning_effort": "low"}
        if chat_template_args is None:
            raw_args = os.environ.get("MLX_CHAT_TEMPLATE_ARGS_JSON", "").strip()
            if raw_args:
                try:
                    chat_template_args = json.loads(raw_args)
                except json.JSONDecodeError:
                    raise SystemExit("MLX_CHAT_TEMPLATE_ARGS_JSON must be valid JSON")
        if chat_template_args is not None:
            argv += ["--chat-template-args", json.dumps(chat_template_args)]

        max_tokens = entry.get("max_output_tokens")
        if isinstance(max_tokens, int) and max_tokens > 0:
            argv += ["--max-tokens", str(max_tokens)]
        proc_env = None

    log_dir = os.environ.get("MLX_LOG_DIR", "/tmp")
    Path(log_dir).mkdir(parents=True, exist_ok=True)
    log_file = Path(log_dir) / f"mlx-{port}.log"
    with log_file.open("a") as handle:
        subprocess.Popen(argv, stdout=handle, stderr=handle, env=proc_env, start_new_session=True)


def _restart_team_lane(port: int):
    cmd_mlx_launch_start(argparse.Namespace(ports=str(port)))


def _stop_team_lane(port: int):
    cmd_mlx_launch_stop(argparse.Namespace(ports=str(port)))


def cmd_load(args):
    if args.port == "auto":
        registry_path = _registry_path()
        data = _load_registry(registry_path)
        port = _available_port(data, EXPERIMENTAL_RANGE)
        if port is None:
            raise SystemExit("no free ports available in experimental range (8120-8139)")
        args.port = str(port)
    port = _parse_port_arg(args.port, arg_name="port", valid_range=PORT_RANGE, range_label="8100-8139")

    registry_path = _registry_path()
    data = _load_registry(registry_path)
    launchd_label = os.environ.get("MLX_LAUNCHD_LABEL", "com.bebop.mlx-launch")
    if not args.ignore_launchd and _launchd_loaded(launchd_label):
        if _prompt_yes_no(f"launchd job {launchd_label} is loaded. Stop it before loading?"):
            _maybe_stop_launchd(launchd_label)
        else:
            raise SystemExit("load cancelled")

    running_pids = _mlx_pids_for_port(port)
    if running_pids or _port_listening(port):
        if args.force:
            cmd_unload(argparse.Namespace(port=str(port), sync=False))
        else:
            slug, _entry = _model_on_port(data, port)
            model_name = slug if slug else "unknown"
            if not _prompt_yes_no(f"model {model_name} already in port {port}. Unload model?"):
                raise SystemExit("load cancelled")
            cmd_unload(argparse.Namespace(port=str(port), sync=False))

    slug, entry = _find_entry(data, args.model)
    converted = False
    if not entry:
        slug, entry, converted = _ensure_model(data, args.model, args.name, args.convert, args.preconverted)
    _ensure_defaults(entry)

    if entry.get("port") and entry.get("port") != port:
        raise SystemExit(f"model already assigned to port {entry['port']}; unload first")

    team_port = port in TEAM_RANGE

    entry["port"] = port
    _write_registry(registry_path, data)

    if team_port:
        _restart_team_lane(port)
    else:
        _launch_server(entry, port)

    startup_timeout = _default_startup_timeout(entry)
    if not _wait_for_port(port, timeout=startup_timeout):
        raise SystemExit(
            f"model failed to start on port {port} within {startup_timeout}s "
            f"(set registry startup_timeout_seconds to override)"
        )

    if _is_gpt_oss_entry(entry):
        model_name = entry.get("model_id") or slug
        if _raw_harmony_tags_detected(port, model_name):
            print(
                "warning: raw Harmony tags detected after load. "
                "check chat_template/tool_call_parser/reasoning_parser settings."
            )
    elif _is_qwen3_entry(entry):
        model_name = entry.get("model_id") or slug
        if _raw_qwen3_tags_detected(port, model_name):
            print(
                "warning: raw Qwen protocol tags detected after load. "
                "check qwen3 parser/template settings."
            )

    if converted and args.offload_og:
        cmd_offload_og(argparse.Namespace(dry_run=False))
    if args.sync:
        cmd_sync_gateway(argparse.Namespace(dry_run=False))
    print(f"loaded {slug} on {port}")


def cmd_unload(args):
    port = _parse_port_arg(args.port, arg_name="port", valid_range=PORT_RANGE, range_label="8100-8139")

    if port in TEAM_RANGE:
        _stop_team_lane(port)
    else:
        _stop_mlx_for_port(port)

    registry_path = _registry_path()
    data = _load_registry(registry_path)
    for entry in data["models"].values():
        if entry.get("port") == port:
            entry["port"] = None
    _write_registry(registry_path, data)
    if args.sync:
        cmd_sync_gateway(argparse.Namespace(dry_run=False))
    print(f"unloaded port {port}")


def cmd_unload_all(args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    running = []
    for port in PORT_RANGE:
        if _port_listening(port) or _mlx_pids_for_port(port):
            slug, _entry = _model_on_port(data, port)
            model_name = slug if slug else "unknown"
            running.append((port, model_name))
    if running:
        print("Currently running models:")
        for port, model_name in running:
            print(f"- {model_name} on {port}")
    else:
        print("No running models detected.")
        return
    if not _prompt_yes_no("Unload all models?"):
        print("unload-all cancelled")
        return
    for port in PORT_RANGE:
        if port in TEAM_RANGE:
            _stop_team_lane(port)
        else:
            _stop_mlx_for_port(port)
        for entry in data["models"].values():
            if entry.get("port") == port:
                entry["port"] = None
    _write_registry(registry_path, data)
    if args.sync:
        cmd_sync_gateway(argparse.Namespace(dry_run=False))
    print("unloaded all ports")


def cmd_reconcile(args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    candidates = []
    changed = 0
    for slug, entry in data["models"].items():
        port = entry.get("port")
        if not port:
            continue
        port = int(port)
        listener_visible = bool(_port_listening(port))
        process_visible = bool(_mlx_pids_for_port(port))
        http_ok = _models_endpoint_ok(port)
        stale = not (listener_visible or process_visible or http_ok)
        if not stale:
            continue
        candidate = {
            "model_id": entry.get("model_id") or slug,
            "slug": slug,
            "port": port,
            "listener_visible": listener_visible,
            "process_visible": process_visible,
            "http_models_ok": http_ok,
        }
        candidates.append(candidate)
        if args.apply:
            entry["port"] = None
            changed += 1

    if args.apply and changed:
        _write_registry(registry_path, data)

    payload = {
        "mode": "apply" if args.apply else "dry-run",
        "candidates": candidates,
        "candidate_count": len(candidates),
        "cleared_count": changed if args.apply else 0,
    }
    if args.json:
        print(json.dumps(payload, indent=2))
        return

    if not candidates:
        print(f"reconcile ({payload['mode']}): no stale assignments found")
        return

    print(f"reconcile ({payload['mode']}): {len(candidates)} stale assignment candidate(s)")
    for row in candidates:
        print(
            f"- {row['model_id']} @ {row['port']} "
            f"(listener={row['listener_visible']} process={row['process_visible']} http={row['http_models_ok']})"
        )
    if args.apply:
        print(f"cleared {changed} stale assignment(s)")
    else:
        print("no changes written (use --apply to clear stale assignments)")


def cmd_verify(_args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    missing = []
    port_to_models = {}
    changed = False
    capabilities = None
    disabled_map = _launchctl_disabled_map()
    for slug, entry in data["models"].items():
        if getattr(_args, "fix_defaults", False):
            if _ensure_defaults(entry):
                changed = True
            check_entry = entry
        else:
            check_entry = dict(entry)
            _ensure_defaults(check_entry)
        if not check_entry.get("context_length"):
            missing.append(f"{slug}: missing context_length")
        if not check_entry.get("max_output_tokens"):
            missing.append(f"{slug}: missing max_output_tokens")
        if _is_gpt_oss_entry(check_entry):
            if check_entry.get("tool_call_parser") != "harmony":
                missing.append(f"{slug}: tool_call_parser must be 'harmony'")
            if check_entry.get("reasoning_parser") != "harmony":
                missing.append(f"{slug}: reasoning_parser must be 'harmony'")
            template = check_entry.get("chat_template")
            if not template:
                missing.append(f"{slug}: missing chat_template")
            elif not Path(template).exists():
                missing.append(f"{slug}: chat_template path missing: {template}")
        if _is_qwen3_entry(check_entry):
            if check_entry.get("tool_call_parser") != "qwen3":
                missing.append(f"{slug}: tool_call_parser must be 'qwen3'")
            if check_entry.get("reasoning_parser") != "qwen3":
                missing.append(f"{slug}: reasoning_parser must be 'qwen3'")
            template = check_entry.get("chat_template")
            if template and not Path(template).exists():
                missing.append(f"{slug}: chat_template path missing: {template}")
        vllm_cfg = _entry_vllm_config(check_entry)
        mode = vllm_cfg.get("tool_choice_mode")
        if mode and mode not in {"none", "auto"}:
            missing.append(f"{slug}: vllm.tool_choice_mode must be 'none' or 'auto'")
        port = check_entry.get("port")
        if port:
            port_to_models.setdefault(int(port), []).append(slug)
            cmd = _mlx_runtime_command_for_port(int(port))
            if not cmd:
                missing.append(f"{slug}: registry port {port} set but no MLX process listening")
            else:
                model_path = _runtime_model_path_from_command(cmd)
                if model_path and check_entry.get("cache_path") and model_path != check_entry.get("cache_path"):
                    missing.append(
                        f"{slug}: runtime path mismatch on {port} "
                        f"(registry={check_entry.get('cache_path')} runtime={model_path})"
                    )
            if int(port) in TEAM_RANGE:
                lane_state = _lane_launchd_state(int(port), disabled_map=disabled_map)
                if lane_state["disabled"] is True:
                    missing.append(
                        f"{slug}: team lane {port} launchd label disabled ({lane_state['label']})"
                    )
                if lane_state["loaded"] is False:
                    missing.append(
                        f"{slug}: team lane {port} launchd label not loaded ({lane_state['label']})"
                    )
                try:
                    if capabilities is None:
                        capabilities = _detect_vllm_capabilities()
                    _compile_vllm_launch(check_entry, int(port), "0.0.0.0", capabilities, validate=True)
                except SystemExit as exc:
                    missing.append(f"{slug}: invalid vllm launch config: {exc}")
    for port, slugs in sorted(port_to_models.items()):
        if len(slugs) > 1:
            missing.append(f"port {port}: multiple registry assignments ({', '.join(sorted(slugs))})")

    # Omni-first routing: if we're on the gateway host, validate served MLX handles exist in registry.json.
    handles_path = Path(os.environ.get("HANDLES_PATH", DEFAULT_HANDLES_PATH))
    if handles_path.exists():
        try:
            handles_rows = _read_handles_jsonl(handles_path)
            served = _served_mlx_handles(handles_rows)
            for row in served:
                handle = row["handle"]
                if _registry_entry_for_handle(data.get("models", {}), handle) is None:
                    missing.append(
                        f"handles.jsonl: served handle missing from registry.json: {handle} ({row.get('endpoint_ref')})"
                    )
        except Exception as exc:
            missing.append(f"handles.jsonl: failed to validate served handles: {exc}")
    if getattr(_args, "fix_defaults", False) and changed:
        _write_registry(registry_path, data)
    if missing:
        raise SystemExit("mlxctl verify failed:\n  - " + "\n  - ".join(missing))
    print("mlxctl verify ok: registry defaults and routing state are consistent")


def cmd_ensemble(args):
    raise SystemExit("mlxctl ensemble is deprecated; use load/assign-team instead")


def cmd_ensure(args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    slug, entry, converted = _ensure_model(data, args.repo, args.name, args.convert, args.preconverted)
    _ensure_defaults(entry)
    _write_registry(registry_path, data)
    if converted and args.offload_og:
        cmd_offload_og(argparse.Namespace(dry_run=False))
    if args.load:
        cmd_load(
            argparse.Namespace(
                model=slug,
                port=args.port,
                force=False,
                ignore_launchd=False,
                convert="skip",
                name=None,
                offload_og=False,
                preconverted="auto",
                sync=args.sync,
            )
        )
    elif args.sync:
        cmd_sync_gateway(argparse.Namespace(dry_run=False))


def _fetch_registry_from_studio(studio_ssh: str, registry_path: str):
    script = f"""
import json
from pathlib import Path
path = Path({registry_path!r})
if not path.exists():
    raise SystemExit(1)
print(path.read_text())
"""
    result = subprocess.run(
        ["ssh", studio_ssh, "python3", "-"],
        input=script.encode("utf-8"),
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit("failed to read MLX registry from studio")
    return _loads_json_or_die(
        result.stdout.decode("utf-8", errors="replace"),
        context="studio registry fetch",
        default="{}",
    )


def _fetch_registry_sizes(studio_ssh: str, registry_path: str):
    script = f"""
import json
import os
from pathlib import Path

path = Path({registry_path!r})
if not path.exists():
    raise SystemExit(1)
data = json.loads(path.read_text() or "{{}}")
models = data.get("models", {{}})

def repo_root(cache_path: str):
    p = Path(cache_path)
    if p.name.startswith("models--") or p.name.startswith("converted--"):
        return p
    for parent in p.parents:
        name = parent.name
        if name.startswith("models--") or name.startswith("converted--"):
            return parent
    return p

def dir_size(root: Path):
    total = 0
    for base, _dirs, files in os.walk(root, followlinks=False):
        for fname in files:
            fpath = os.path.join(base, fname)
            if os.path.islink(fpath):
                continue
            try:
                total += os.path.getsize(fpath)
            except OSError:
                continue
    return total

rows = []
for slug, entry in models.items():
    cache_path = entry.get("cache_path")
    if not cache_path:
        continue
    root = repo_root(cache_path)
    if not root.exists():
        continue
    rows.append({{
        "slug": slug,
        "model_id": entry.get("model_id") or slug,
        "cache_path": str(cache_path),
        "root": str(root),
        "size_bytes": dir_size(root),
        "port": entry.get("port"),
    }})
print(json.dumps(rows))
"""
    result = subprocess.run(
        ["ssh", studio_ssh, "python3", "-"],
        input=script.encode("utf-8"),
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit("failed to read MLX registry sizes from studio")
    return _loads_json_or_die(
        result.stdout.decode("utf-8", errors="replace"),
        context="studio registry-size fetch",
        default="[]",
    )


def _optillm_models_from_handles(path: Path):
    if not path.exists():
        raise SystemExit(f"handles.jsonl not found: {path}")
    models = set()
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        handle = obj.get("handle", "")
        if not handle.startswith("opt-"):
            continue
        selector = obj.get("selector") or {}
        model = selector.get("model")
        if not model:
            continue
        for match in re.findall(r"mlx-[a-z0-9-]+", str(model)):
            models.add(match)
    return models


def _apply_port_map(assignments, studio_ssh: str, sync: bool):
    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    failures = []
    for handle, port in assignments:
        cmd = [
            "ssh",
            studio_ssh,
            studio_cmd,
            "--local",
            "load",
            handle,
            str(port),
            "--force",
            "--ignore-launchd",
            "--no-sync",
        ]
        result = subprocess.run(cmd, check=False)
        if result.returncode != 0:
            failures.append((handle, port, result.returncode))
    if failures:
        details = ", ".join([f"{h}@{p} (exit {rc})" for h, p, rc in failures])
        raise SystemExit(f"assign-team failed while applying loads: {details}")
    if sync:
        cmd_sync_gateway(argparse.Namespace(dry_run=False))


def cmd_assign_team(args):
    studio_ssh = os.environ.get("STUDIO_SSH", "thestudio@192.168.1.72")
    handles_path = Path(os.environ.get("HANDLES_PATH", DEFAULT_HANDLES_PATH))
    registry_path = os.environ.get("MLX_REGISTRY_PATH", DEFAULT_REGISTRY)

    # Ensure registry includes all cached models on actual apply.
    if not args.dry_run:
        subprocess.run(
            ["ssh", studio_ssh, os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl"), "--local", "init"],
            check=True,
        )

    optillm_models = _optillm_models_from_handles(handles_path)
    rows = _fetch_registry_sizes(studio_ssh, registry_path)
    if not rows:
        raise SystemExit("no MLX models found in registry")

    by_handle = {row["model_id"]: row for row in rows}
    opt_rows = [row for handle, row in by_handle.items() if handle in optillm_models]
    other_rows = [row for handle, row in by_handle.items() if handle not in optillm_models]

    opt_rows.sort(key=lambda r: (-r["size_bytes"], r["model_id"]))
    other_rows.sort(key=lambda r: (-r["size_bytes"], r["model_id"]))

    opt_ports = list(range(8100, 8110))
    other_ports = list(range(8110, 8120))

    if len(opt_rows) > len(opt_ports):
        raise SystemExit("too many optillm models for 8100-8109")
    if len(other_rows) > len(other_ports):
        raise SystemExit("too many non-optillm models for 8110-8119")

    assignments = []
    for row, port in zip(opt_rows, opt_ports):
        assignments.append((row["model_id"], port))
    for row, port in zip(other_rows, other_ports):
        assignments.append((row["model_id"], port))

    if args.dry_run:
        print(json.dumps({"count": len(assignments), "assignments": assignments}, indent=2))
        return

    _apply_port_map(assignments, studio_ssh, sync=args.sync)


def cmd_studio_cli_sha(_args):
    local_path = Path(__file__).resolve()
    local_sha = _sha256_path(local_path)
    studio_host = _studio_ssh_target()
    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    remote_sha = _studio_cli_sha(studio_host, studio_cmd)
    payload = {
        "local_path": str(local_path),
        "local_sha256": local_sha,
        "studio_host": _studio_host_label(),
        "studio_ssh_target": studio_host,
        "studio_path": studio_cmd,
        "studio_sha256": remote_sha,
        "match": bool(remote_sha and remote_sha == local_sha),
    }
    print(json.dumps(payload, indent=2))
    if not payload["match"]:
        raise SystemExit(1)


def cmd_sync_studio_cli(_args):
    local_path = Path(__file__).resolve()
    studio_host = _studio_ssh_target()
    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    stamp = int(time.time())
    backup = f"{studio_cmd}.bak-{stamp}"
    tmp = f"/tmp/mlxctl.sync.{stamp}"
    payload = local_path.read_bytes()
    remote = (
        "set -euo pipefail; "
        f"cat > {shlex.quote(tmp)}; "
        f"if [ -f {shlex.quote(studio_cmd)} ]; then cp {shlex.quote(studio_cmd)} {shlex.quote(backup)}; fi; "
        f"install -m 0755 {shlex.quote(tmp)} {shlex.quote(studio_cmd)}; "
        f"rm -f {shlex.quote(tmp)}"
    )
    _ssh_cmd(studio_host, remote, input_bytes=payload, check=True)
    local_sha = _sha256_path(local_path)
    remote_sha = _studio_cli_sha(studio_host, studio_cmd)
    if remote_sha != local_sha:
        raise SystemExit("sync-studio-cli: hash mismatch after copy")
    print(
        json.dumps(
            {
                "synced": True,
                "studio_host": _studio_host_label(),
                "studio_ssh_target": studio_host,
                "studio_path": studio_cmd,
                "backup": backup,
                "sha256": local_sha,
            },
            indent=2,
        )
    )


def _env_key(handle: str, suffix: str):
    key = handle.upper().replace("-", "_")
    return f"MLX_{key}_{suffix}"


def _gateway_env_local_path() -> Path:
    gateway_root = Path(os.environ.get("GATEWAY_ROOT", DEFAULT_GATEWAY_ROOT))
    return gateway_root / "layer-gateway/litellm-orch/config/env.local"


def _read_env_assignments_from_lines(lines) -> dict[str, str]:
    env = {}
    for raw in lines:
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export "):
            line = line[len("export ") :].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
            value = value[1:-1]
        env[key] = value
    return env


def _read_env_assignments(path: Path) -> dict[str, str]:
    if not path.exists():
        return {}
    return _read_env_assignments_from_lines(path.read_text().splitlines())


def _lane_handle_for_entry(entry: dict) -> str:
    handle = str(entry.get("model_id") or entry.get("served_model_name") or "").strip()
    if not handle:
        raise SystemExit("registry entry missing model_id/served_model_name for lane auth")
    return handle


def _resolve_lane_api_key(entry: dict, env_assignments: Optional[dict[str, str]] = None) -> tuple[str, str]:
    env_name = _env_key(_lane_handle_for_entry(entry), "API_KEY")
    value = os.environ.get(env_name)
    if value is None:
        if env_assignments is None:
            env_assignments = _read_env_assignments(_gateway_env_local_path())
        value = env_assignments.get(env_name, "")
    return env_name, str(value).strip()


def _is_blank_or_dummy_auth(value: Optional[str]) -> bool:
    normalized = str(value or "").strip()
    return not normalized or normalized.lower() == "dummy"


def _validated_lane_api_key(entry: dict, env_assignments: Optional[dict[str, str]] = None) -> tuple[str, str]:
    env_name, value = _resolve_lane_api_key(entry, env_assignments=env_assignments)
    if _is_blank_or_dummy_auth(value):
        handle = _lane_handle_for_entry(entry)
        port = entry.get("port")
        lane_text = f"{handle} on {port}" if port else handle
        raise SystemExit(
            f"{lane_text} requires non-dummy {env_name} in "
            "layer-gateway/litellm-orch/config/env.local or the current environment"
        )
    return env_name, value

_EP_PORT_RE = re.compile(r"^ep_mlx_(?:omni|slot)_(\d+)$")


def _endpoint_ref_port(endpoint_ref: str) -> Optional[int]:
    if not endpoint_ref:
        return None
    m = _EP_PORT_RE.match(endpoint_ref.strip())
    if not m:
        return None
    try:
        return int(m.group(1))
    except ValueError:
        return None


def _read_handles_jsonl(path: Path):
    if not path.exists():
        raise SystemExit(f"handles.jsonl not found: {path}")
    rows = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(obj, dict):
            rows.append(obj)
    return rows


def _served_mlx_handles(handles_rows):
    """Return handles served by MLX backends.

    Omni-first: treat handles pointing at ep_mlx_omni_<port> as served.
    Also accept legacy ep_mlx_slot_<port> for transition.
    """
    served = []
    for obj in handles_rows:
        handle = obj.get("handle")
        if not handle or not isinstance(handle, str):
            continue
        endpoint_ref = obj.get("endpoint_ref") or ""
        if not isinstance(endpoint_ref, str):
            continue
        if endpoint_ref.startswith("ep_mlx_omni_") or endpoint_ref.startswith("ep_mlx_slot_"):
            served.append(
                {
                    "handle": handle,
                    "endpoint_ref": endpoint_ref,
                    "selector": obj.get("selector") or {},
                }
            )
    return served


def _registry_entry_for_handle(models: dict, handle: str) -> Optional[dict]:
    entry = models.get(handle)
    if entry:
        return entry
    for _slug, e in (models or {}).items():
        if e.get("model_id") == handle:
            return e
    return None


def _build_mlx_entries(models, host: str):
    items = []
    for slug, entry in models.items():
        port = entry.get("port")
        if not port:
            continue
        handle = entry.get("model_id") or slug
        items.append(
            {
                "handle": handle,
                "port": int(port),
                "request_params": entry.get("request_params", {}),
                "context_length": entry.get("context_length"),
                "max_output_tokens": entry.get("max_output_tokens"),
            }
        )
    return sorted(items, key=lambda i: i["port"])



def _yaml_scalar(value):
    if value is None:
        return "null"
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, (int, float)):
        return str(value)
    if isinstance(value, str):
        return json.dumps(value)
    raise SystemExit(f"unsupported request_param type: {type(value)}")


def _update_router_yaml(path: Path, mlx_entries):
    if not path.exists():
        raise SystemExit(f"router.yaml not found: {path}")
    lines = path.read_text().splitlines()
    begin = "# BEGIN MLXCTL AUTO"
    end = "# END MLXCTL AUTO"

    # Remove existing MLX entries (legacy or previous sync)
    new_lines = []
    skip = False
    skip_block = False
    for line in lines:
        if line.strip() == begin:
            skip = True
            continue
        if line.strip() == end:
            skip = False
            continue
        if skip:
            continue
        if line.startswith("- model_name: "):
            if line.startswith("- model_name: mlx-"):
                skip_block = True
                continue
            skip_block = False
        if skip_block:
            continue
        new_lines.append(line)

    block = [
        begin,
        "# MLX model entries omitted (aliases-only model_list).",
        "# Canonical model_ids remain in the MLX registry and env.local.",
        end,
    ]

    inserted = False
    output = []
    for line in new_lines:
        output.append(line)
        if line.strip() == "model_list:" and not inserted:
            output.extend(block)
            inserted = True
    if not inserted:
        output = block + new_lines
    path.write_text("\n".join(output) + "\n")


def _update_env_local(path: Path, mlx_entries, host: str):
    if not path.exists():
        raise SystemExit(f"env.local not found: {path}")
    begin = "# BEGIN MLXCTL AUTO"
    end = "# END MLXCTL AUTO"
    lines = path.read_text().splitlines()
    existing = _read_env_assignments_from_lines(lines)
    output = []
    skip = False
    for line in lines:
        if line.strip() == begin:
            skip = True
            continue
        if line.strip() == end:
            skip = False
            continue
        if skip:
            continue
        if (
            line.startswith("JERRY_")
            or line.startswith("BENCH_")
            or line.startswith("MLX_")
            or line.startswith("ROUTER_")
            or line.startswith("SWAP_")
        ):
            continue
        output.append(line)

    block = [begin, "# MLX backend base URLs (auto-generated; Omni-first)"]
    single_api_base = os.environ.get("MLX_SINGLE_API_BASE")
    default_omni_port = int(os.environ.get("MLX_OMNI_PORT", "8100"))
    for item in mlx_entries:
        handle = item["handle"]
        endpoint_port = item.get("endpoint_port")
        port = int(endpoint_port) if endpoint_port else default_omni_port
        api_base = single_api_base or f"http://{host}:{port}/v1"
        block.append(f"{_env_key(handle, 'API_BASE')}={api_base}")
    block.append("")
    block.append("# Upstream model IDs (prefix with \"openai/\" for OpenAI-compatible backends)")
    for item in mlx_entries:
        handle = item["handle"]
        block.append(f"{_env_key(handle, 'MODEL')}=openai/{handle}")
    block.append("")
    block.append("# API keys for active MLX team lanes (required when backend auth is enforced)")
    for item in mlx_entries:
        handle = item["handle"]
        key_name = _env_key(handle, "API_KEY")
        key_value = os.environ.get(key_name, existing.get(key_name, "")).strip()
        if key_value.lower() == "dummy":
            key_value = ""
        block.append(f"{key_name}={key_value}")
    block.append("")
    block.append("# Swap endpoint defaults (kept aligned with the MLX backend)")
    swap_api_base = single_api_base or f"http://{host}:{default_omni_port}/v1"
    block.append(f"SWAP_API_BASE={swap_api_base}")
    # swap remains a model id passed to the backend; keep it compatible with existing behavior.
    # (The backend should strip the 'openai/' prefix if it does not use OpenAI provider routing.)
    block.append("SWAP_MODEL=openai/mlx-gpt-oss-20b-mxfp4-q4")
    swap_api_key = os.environ.get("SWAP_API_KEY", existing.get("SWAP_API_KEY", "")).strip()
    if swap_api_key.lower() == "dummy":
        swap_api_key = ""
    block.append(f"SWAP_API_KEY={swap_api_key}")
    # OptiLLM routing block removed (deprecated).
    block.append(end)

    output.append("")
    output.extend(block)
    path.write_text("\n".join(output).rstrip() + "\n")


def _update_handles(path: Path, mlx_entries):
    if not path.exists():
        raise SystemExit(f"handles.jsonl not found: {path}")
    replace_handles = {item["handle"] for item in mlx_entries}
    rows = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            rows.append(line)
            continue
        handle = obj.get("handle", "")
        endpoint = obj.get("endpoint_ref", "")
        # Drop any previously-generated MLX handle entries so we can re-add them deterministically.
        if (
            handle in replace_handles
            or handle.startswith("mlx-")
            or endpoint.startswith("ep_mlx_slot_")
            or endpoint.startswith("ep_mlx_omni_")
            or endpoint.startswith("ep_mlx_")
        ):
            continue
        rows.append(obj)

    single_endpoint_ref = os.environ.get("MLX_SINGLE_ENDPOINT_REF")
    for item in mlx_entries:
        handle = item["handle"]
        port = item["port"]
        endpoint_ref = f"ep_mlx_slot_{port}"
        if single_endpoint_ref:
            endpoint_ref = single_endpoint_ref
        rows.append(
            {
                "handle": handle,
                "kind": "model",
                "invoke": "openai-chat",
                "managed_by": "launchd",
                "endpoint_ref": endpoint_ref,
                "selector": {"model": handle},
            }
        )

    with path.open("w") as handle_out:
        for row in rows:
            if isinstance(row, str):
                handle_out.write(row + "\n")
            else:
                handle_out.write(json.dumps(row, separators=(",", ":")) + "\n")




def cmd_sync_gateway(args):
    gateway_root = Path(os.environ.get("GATEWAY_ROOT", DEFAULT_GATEWAY_ROOT))
    router_path = gateway_root / "layer-gateway/litellm-orch/config/router.yaml"
    env_path = gateway_root / "layer-gateway/litellm-orch/config/env.local"
    handles_path = gateway_root / "layer-gateway/registry/handles.jsonl"

    if not router_path.exists():
        gateway_host = os.environ.get("GATEWAY_HOST", DEFAULT_GATEWAY_HOST)
        gateway_mlxctl = os.environ.get("GATEWAY_MLXCTL", DEFAULT_GATEWAY_MLXCTL)
        remote_cmd = [gateway_mlxctl, "--local", "sync-gateway"]
        if args.dry_run:
            remote_cmd.append("--dry-run")
        subprocess.run(["ssh", gateway_host] + remote_cmd, check=False)
        return

    studio_ssh = os.environ.get("STUDIO_SSH", "thestudio@192.168.1.72")
    registry_path = os.environ.get("MLX_REGISTRY_PATH", DEFAULT_REGISTRY)
    registry = _fetch_registry_from_studio(studio_ssh, registry_path)
    handles_rows = _read_handles_jsonl(handles_path)
    served = _served_mlx_handles(handles_rows)
    models = registry.get("models", {}) or {}

    # Omni-first: the served set is curated via handles.jsonl; do not rely on registry.port.
    mlx_entries = []
    for row in served:
        handle = row["handle"]
        endpoint_ref = row.get("endpoint_ref") or ""
        endpoint_port = _endpoint_ref_port(endpoint_ref)
        reg_entry = _registry_entry_for_handle(models, handle) or {}
        mlx_entries.append(
            {
                "handle": handle,
                "endpoint_ref": endpoint_ref,
                "endpoint_port": endpoint_port,
                "request_params": reg_entry.get("request_params", {}),
                "context_length": reg_entry.get("context_length"),
                "max_output_tokens": reg_entry.get("max_output_tokens"),
            }
        )
    mlx_entries.sort(key=lambda r: ((r.get("endpoint_port") or 0), r.get("handle") or ""))

    if args.dry_run:
        print(json.dumps({"count": len(mlx_entries), "entries": mlx_entries}, indent=2))
        return

    _update_router_yaml(router_path, mlx_entries)
    _update_env_local(env_path, mlx_entries, os.environ.get("MLX_HOST", DEFAULT_MLX_HOST))
    # NOTE: handles.jsonl is treated as a curated served-set source; sync does not rewrite it.


def cmd_omni_install(args):
    """
    Install and run mlx-omni-server on the Studio under /opt/mlx-omni-launch.

    Orchestrated from the caller host (Mini) so we can ship a pinned patch without
    requiring the monorepo to be present on the Studio.
    """
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    repo = os.environ.get("MLX_OMNI_REPO", DEFAULT_OMNI_REPO)
    ref = os.environ.get("MLX_OMNI_REF", DEFAULT_OMNI_REF)
    install_dir = os.environ.get("MLX_OMNI_DIR", DEFAULT_OMNI_DIR)
    port = _parse_port_arg(args.port, arg_name="--port", valid_range=PORT_RANGE, range_label="8100-8139")
    bind_host = args.host

    label_prefix = os.environ.get("MLX_OMNI_LABEL_PREFIX", DEFAULT_OMNI_LABEL_PREFIX)
    label = f"{label_prefix}.{port}"

    # Disk check before installing python deps on Studio.
    _ssh_cmd(studio_ssh, "df -h / /Users/thestudio 2>/dev/null || df -h /", check=False)

    # Prepare install dir
    _studio_sudo_cmd(studio_ssh, f"mkdir -p {shlex.quote(install_dir)}")
    _studio_sudo_cmd(studio_ssh, f"chown -R thestudio:staff {shlex.quote(install_dir)}")

    # Clone/update and pin
    remote_setup = f"""
set -euo pipefail
cd {shlex.quote(install_dir)}
if [ ! -d .git ]; then
  git init
  git remote add origin {shlex.quote(repo)}
fi
git fetch --tags --force origin
git checkout -f {shlex.quote(ref)}
git clean -fd
"""
    _ssh_cmd(studio_ssh, remote_setup)

    # Apply patch (best-effort idempotency via --check)
    gateway_root = Path(os.environ.get("GATEWAY_ROOT", DEFAULT_GATEWAY_ROOT))
    patch_path = gateway_root / "platform/ops/patches/mlx-omni-server-v0.5.2.patch"
    patch_bytes = _read_patch_bytes(patch_path)
    remote_apply = f"""
set -euo pipefail
cd {shlex.quote(install_dir)}
tmp_patch="$(mktemp)"
cat > "$tmp_patch"
if git apply --check "$tmp_patch" >/dev/null 2>&1; then
  git apply "$tmp_patch"
fi
rm -f "$tmp_patch"
"""
    _ssh_cmd(studio_ssh, remote_apply, input_bytes=patch_bytes, check=True)

    # Ensure uv exists on Studio
    _ssh_cmd(
        studio_ssh,
        "command -v uv >/dev/null 2>&1 || (echo 'uv not found on Studio (install uv first)' >&2; exit 2)",
    )

    # Install into local venv (editable install to keep patch active)
    remote_install = f"""
set -euo pipefail
cd {shlex.quote(install_dir)}
uv venv .venv
uv pip install -e .
"""
    _ssh_cmd(studio_ssh, remote_install)

    # launchd plist (system-wide)
    registry_path = os.environ.get("MLX_OMNI_REGISTRY_PATH", DEFAULT_REGISTRY)
    hf_home = os.environ.get("HF_HOME", DEFAULT_HF_HOME)
    cache_max = os.environ.get("MLX_OMNI_CACHE_MAX_SIZE", "3")
    cache_ttl = os.environ.get("MLX_OMNI_CACHE_TTL_SECONDS", "0")
    prewarm = os.environ.get(
        "MLX_OMNI_PREWARM_MODELS",
        "txgsync-gpt-oss-120b-derestricted-mxfp4-mlx,mlx-qwen3-next-80b-mxfp4-a3b-instruct,mlx-gpt-oss-20b-mxfp4-q4",
    )
    enabled_decoders = os.environ.get(
        "MLX_OMNI_ENABLED_DECODERS",
        "entropy_decoding,thinkdeeper,deepconf",
    )
    deepconf_max_n = os.environ.get("MLX_OMNI_DEEPCONF_MAX_N", "8")

    plist_path = f"/Library/LaunchDaemons/{label}.plist"
    log_path = f"/tmp/mlx-omni-{port}.log"
    program = f"{install_dir}/.venv/bin/mlx-omni-server"

    plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{label}</string>
  <key>WorkingDirectory</key><string>{install_dir}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{program}</string>
    <string>--host</string><string>{bind_host}</string>
    <string>--port</string><string>{port}</string>
    <string>--workers</string><string>1</string>
    <string>--log-level</string><string>info</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>{log_path}</string>
  <key>StandardErrorPath</key><string>{log_path}</string>
    <key>EnvironmentVariables</key>
  <dict>
    <key>HF_HOME</key><string>{hf_home}</string>
    <key>MLX_OMNI_REGISTRY_PATH</key><string>{registry_path}</string>
    <key>MLX_OMNI_CACHE_MAX_SIZE</key><string>{cache_max}</string>
    <key>MLX_OMNI_CACHE_TTL_SECONDS</key><string>{cache_ttl}</string>
    <key>MLX_OMNI_PREWARM_MODELS</key><string>{prewarm}</string>
    <key>MLX_OMNI_ENABLED_DECODERS</key><string>{enabled_decoders}</string>
    <key>MLX_OMNI_DEEPCONF_MAX_N</key><string>{deepconf_max_n}</string>
  </dict>
</dict>
</plist>
"""

    remote_plist = f"""
set -euo pipefail
cat > {shlex.quote(plist_path)} <<'PLIST'
{plist}
PLIST
chown root:wheel {shlex.quote(plist_path)}
chmod 0644 {shlex.quote(plist_path)}
# bootout-by-path is more reliable than bootout-by-label on recent macOS.
launchctl bootout system {shlex.quote(plist_path)} >/dev/null 2>&1 || true
launchctl bootstrap system {shlex.quote(plist_path)}
launchctl kickstart -k system/{shlex.quote(label)}
"""
    _studio_sudo_cmd(studio_ssh, remote_plist)

    # Basic health
    _ssh_cmd(studio_ssh, f"curl -fsS http://127.0.0.1:{port}/v1/models | head -c 200 >/dev/null")
    print(f"omni installed and started: {label} (port {port})")


def cmd_omni_stop(args):
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    port = _parse_port_arg(args.port, arg_name="--port", valid_range=PORT_RANGE, range_label="8100-8139")
    label_prefix = os.environ.get("MLX_OMNI_LABEL_PREFIX", DEFAULT_OMNI_LABEL_PREFIX)
    label = f"{label_prefix}.{port}"
    plist_path = f"/Library/LaunchDaemons/{label}.plist"
    remote = f"""
set -euo pipefail
launchctl bootout system {shlex.quote(plist_path)} >/dev/null 2>&1 || true
rm -f {shlex.quote(plist_path)}
"""
    _studio_sudo_cmd(studio_ssh, remote, check=False)
    print(f"omni stopped: {label}")


def cmd_omni_status(args):
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    port = _parse_port_arg(args.port, arg_name="--port", valid_range=PORT_RANGE, range_label="8100-8139")
    _studio_sudo_cmd(studio_ssh, f"lsof -nP -iTCP:{port} -sTCP:LISTEN || true", check=False)
    _ssh_cmd(
        studio_ssh,
        f"curl -fsS http://127.0.0.1:{port}/v1/models | jq -r '.data[].id' 2>/dev/null || curl -fsS http://127.0.0.1:{port}/v1/models",
        check=False,
    )


def cmd_omni_warm(args):
    """Warm one or more models into the running mlx-omni-server process.

    Omni loads models lazily on first request; warming makes the first "real" request fast.
    """
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    port = _parse_port_arg(args.port, arg_name="--port", valid_range=PORT_RANGE, range_label="8100-8139")
    timeout = _parse_int_arg(args.timeout, arg_name="--timeout")
    max_tokens = _parse_int_arg(args.max_tokens, arg_name="--max-tokens")

    for model in args.models:
        payload = {
            "model": model,
            "messages": [{"role": "user", "content": "warm"}],
            "max_tokens": max_tokens,
            "temperature": 0,
        }
        script = f"""
import json
from urllib import request as urlrequest

payload = {json.dumps(payload)}
req = urlrequest.Request(
    "http://127.0.0.1:{port}/v1/chat/completions",
    data=json.dumps(payload).encode("utf-8"),
    headers={{"Content-Type": "application/json"}},
    method="POST",
)
with urlrequest.urlopen(req, timeout={timeout}) as resp:
    resp.read()
print("warmed", payload.get("model"))
"""
        _ssh_cmd(studio_ssh, "python3 -", input_bytes=script.encode("utf-8"), check=True)


def _resolve_team_target_ports(raw_ports: Optional[str]) -> list[int]:
    return _parse_port_csv(raw_ports, arg_name="--ports", valid_range=TEAM_RANGE, range_label="8100-8119")


def _render_vllm_rows_for_ports(target_ports: list[int], *, host: str, validate: bool) -> dict:
    data = _load_registry(_registry_path())
    capabilities = _detect_vllm_capabilities()
    rows = []
    for slug, entry in (data.get("models") or {}).items():
        port = entry.get("port")
        try:
            port = int(port)
        except Exception:
            continue
        if port not in TEAM_RANGE:
            continue
        if target_ports and port not in target_ports:
            continue
        model_path = entry.get("cache_path")
        if not model_path or not Path(model_path).exists():
            continue
        compiled = _compile_vllm_launch(entry, port, host, capabilities, validate=validate)
        rows.append(
            {
                "slug": slug,
                "model": entry.get("model_id") or slug,
                "port": port,
                "path": model_path,
                "argv": compiled["argv"],
                "env": compiled["env"],
                "profile": compiled["profile"],
                "tool_choice_mode": compiled["tool_choice_mode"],
                "tool_call_parser_logical": compiled["tool_call_parser_logical"],
                "tool_call_parser_resolved": compiled["tool_call_parser_resolved"],
                "reasoning_parser": compiled["reasoning_parser"],
            }
        )
    rows.sort(key=lambda row: row["port"])
    return {"rows": rows, "capabilities": capabilities}


def cmd_vllm_capabilities(args):
    caps = _detect_vllm_capabilities()
    if getattr(args, "json", False):
        print(json.dumps(caps, indent=2))
        return
    print(f"vllm_bin={caps.get('vllm_bin')}")
    print(f"supports_auto_tool_choice={caps.get('supports_auto_tool_choice')}")
    print(f"supports_tool_call_parser={caps.get('supports_tool_call_parser')}")
    print(f"supports_reasoning_parser={caps.get('supports_reasoning_parser')}")
    parsers = caps.get("tool_call_parsers") or []
    print("tool_call_parsers=" + (",".join(parsers) if parsers else "(none)"))


def cmd_vllm_render(args):
    target_ports = _resolve_team_target_ports(getattr(args, "ports", ""))
    host = os.environ.get("MLX_BIND_HOST", "0.0.0.0").strip() or "0.0.0.0"
    payload = _render_vllm_rows_for_ports(target_ports, host=host, validate=bool(getattr(args, "validate", False)))
    if getattr(args, "json", False):
        print(json.dumps(payload, indent=2))
        return
    rows = payload["rows"]
    if not rows:
        print("no assigned team-lane models in registry")
        return
    for row in rows:
        print(
            f"{row['port']}\t{row['model']}\tprofile={row['profile']}\t"
            f"tool_choice={row['tool_choice_mode']}\tparser={row['tool_call_parser_resolved'] or '-'}"
        )
        print("  " + " ".join(shlex.quote(token) for token in row["argv"]))


def cmd_vllm_set(args):
    registry_path = _registry_path()
    data = _load_registry(registry_path)
    slug, entry = _find_entry(data, args.model)
    if not entry:
        raise SystemExit(f"model not found in registry: {args.model}")
    _ensure_defaults(entry)
    vllm = _entry_vllm_config(entry)
    if args.clear_vllm:
        entry["vllm"] = {}
        _write_registry(registry_path, data)
        print(f"updated {slug}: cleared vllm block")
        return
    if args.profile:
        vllm["profile"] = args.profile
    if args.max_model_len is not None:
        vllm["max_model_len"] = int(args.max_model_len)
        entry["vllm_max_model_len"] = int(args.max_model_len)
    if args.memory_fraction is not None:
        vllm["memory_fraction"] = str(args.memory_fraction)
        entry["vllm_memory_fraction"] = str(args.memory_fraction)
    if args.async_scheduling is not None:
        vllm["async_scheduling"] = bool(args.async_scheduling)
        entry["vllm_async_scheduling"] = bool(args.async_scheduling)
    if args.tool_choice_mode:
        vllm["tool_choice_mode"] = args.tool_choice_mode
    if args.tool_call_parser:
        vllm["tool_call_parser"] = args.tool_call_parser
        entry["tool_call_parser"] = args.tool_call_parser
    if args.reasoning_parser:
        vllm["reasoning_parser"] = args.reasoning_parser
        entry["reasoning_parser"] = args.reasoning_parser
    _write_registry(registry_path, data)
    print(f"updated {slug}: vllm settings applied")


def cmd_mlx_launch_configure_vllm(args):
    """Write a registry-driven legacy start script for com.bebop.mlx-launch."""
    if os.environ.get("MLX_ALLOW_LEGACY", "0").strip().lower() not in {"1", "true", "yes"}:
        raise SystemExit(
            "mlx-launch-configure-vllm is legacy. Set MLX_ALLOW_LEGACY=1 to run."
        )
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    start_path = os.environ.get("MLX_LAUNCH_START_PATH", DEFAULT_MLX_LAUNCH_START_PATH)
    backup_path = f"{start_path}.bak-{int(time.time())}-pre-vllm-metal"

    _ssh_cmd(
        studio_ssh,
        f"set -euo pipefail; if [ -f {shlex.quote(start_path)} ]; then cp {shlex.quote(start_path)} {shlex.quote(backup_path)}; fi",
        check=True,
    )
    _ssh_cmd(studio_ssh, f"cat > {shlex.quote(start_path)}", input_bytes=_render_vllm_launch_start_script().encode("utf-8"), check=True)
    _ssh_cmd(studio_ssh, f"chmod 0755 {shlex.quote(start_path)}", check=True)
    print(f"configured mlx-launch start script for vllm-metal: {start_path}")
    print(f"backup: {backup_path}")


def cmd_mlx_launch_stop(args):
    """Stop managed team-lane launchd jobs (non-interactive).

    This does NOT mutate registry port assignments; it only stops the running services so
    we can safely reconfigure or restart managed team lanes.
    """
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    lane_label_prefix = os.environ.get("MLX_LANE_LABEL_PREFIX", DEFAULT_MLX_LANE_LABEL_PREFIX)
    legacy_label = os.environ.get("MLX_LAUNCHD_LABEL", os.environ.get("MLX_OPENAI_LAUNCHD_LABEL", DEFAULT_MLX_LAUNCHD_LABEL))
    ports = _parse_port_csv(
        args.ports or "8100,8101,8102",
        arg_name="--ports",
        valid_range=TEAM_RANGE,
        range_label="8100-8119",
    )

    # Stop/disable per-lane jobs first.
    for port in ports:
        label = f"{lane_label_prefix}.{port}"
        plist = f"/Library/LaunchDaemons/{label}.plist"
        _studio_sudo_cmd(studio_ssh, f"launchctl bootout system/{shlex.quote(label)} >/dev/null 2>&1 || true", check=False)
        _studio_sudo_cmd(studio_ssh, f"launchctl bootout system {shlex.quote(plist)} >/dev/null 2>&1 || true", check=False)
        _studio_sudo_cmd(studio_ssh, f"launchctl disable system/{shlex.quote(label)} >/dev/null 2>&1 || true", check=False)

    # Stop/disable legacy supervisor so it does not respawn children.
    _studio_sudo_cmd(studio_ssh, f"launchctl bootout system/{shlex.quote(legacy_label)} >/dev/null 2>&1 || true", check=False)
    _studio_sudo_cmd(studio_ssh, f"launchctl disable system/{shlex.quote(legacy_label)} >/dev/null 2>&1 || true", check=False)

    # Ensure team-lane listeners are gone (they can outlive the supervisor).
    # Be conservative: only kill MLX/vLLM families used for team lanes.
    remote = ["set -euo pipefail"]
    for port in ports:
        remote.append(f"pids=$(lsof -tiTCP:{port} -sTCP:LISTEN 2>/dev/null || true)")
        remote.append('for pid in ${pids}; do')
        remote.append('  cmd=$(ps -p ${pid} -o command= 2>/dev/null || true)')
        remote.append('  echo \"${cmd}\" | rg -q \"vllm serve|mlx_lm\\.server|mlx-openai-server|mlx_openai_server\" || continue')
        remote.append('  kill ${pid} >/dev/null 2>&1 || true; sleep 0.2; kill -9 ${pid} >/dev/null 2>&1 || true')
        remote.append('done')
    _studio_sudo_cmd(studio_ssh, "\n".join(remote), check=False)
    port_text = ",".join(str(port) for port in ports)
    print(
        f"stopped per-lane launchd jobs ({lane_label_prefix}.*), disabled legacy {legacy_label}, "
        f"and cleared listeners for ports: {port_text}"
    )


def cmd_mlx_launch_start(args):
    """Start per-lane launchd jobs for assigned team lanes (8100-8119)."""
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    host = os.environ.get("MLX_BIND_HOST", "0.0.0.0").strip() or "0.0.0.0"
    log_dir = os.environ.get("MLX_VLLM_LOG_DIR", "/Users/thestudio")
    lane_label_prefix = os.environ.get("MLX_LANE_LABEL_PREFIX", DEFAULT_MLX_LANE_LABEL_PREFIX)
    legacy_label = os.environ.get("MLX_LAUNCHD_LABEL", os.environ.get("MLX_OPENAI_LAUNCHD_LABEL", DEFAULT_MLX_LAUNCHD_LABEL))
    legacy_plist = os.environ.get("MLX_LAUNCHD_PLIST", os.environ.get("MLX_OPENAI_LAUNCHD_PLIST", DEFAULT_MLX_LAUNCHD_PLIST))
    target_ports = _parse_port_csv(
        args.ports,
        arg_name="--ports",
        valid_range=TEAM_RANGE,
        range_label="8100-8119",
    )
    allow_partial = bool(getattr(args, "allow_partial", False))

    studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
    render_argv = [studio_cmd, "--local", "vllm-render", "--validate", "--json"]
    if target_ports:
        render_argv += ["--ports", ",".join(str(p) for p in sorted(set(target_ports)))]
    render_result = _ssh_cmd(studio_ssh, render_argv, check=True)
    payload = json.loads((render_result.stdout or b"{}").decode("utf-8", errors="replace"))
    rows = payload.get("rows") or []
    if not rows:
        raise SystemExit("no assigned team-lane models in registry")
    if target_ports and not allow_partial:
        all_result = _ssh_cmd(studio_ssh, [studio_cmd, "--local", "vllm-render", "--validate", "--json"], check=True)
        all_payload = json.loads((all_result.stdout or b"{}").decode("utf-8", errors="replace"))
        assigned_ports = sorted({int(row["port"]) for row in (all_payload.get("rows") or [])})
        scoped_ports = sorted(set(target_ports))
        if assigned_ports and scoped_ports != assigned_ports:
            raise SystemExit(
                "refusing partial mlx-launch-start scope; assigned team lanes are "
                f"{','.join(str(p) for p in assigned_ports)} but --ports requested "
                f"{','.join(str(p) for p in scoped_ports)}. Use --allow-partial to override."
            )

    script = f"""
import json
import os
import plistlib
import subprocess
from pathlib import Path

HOST = {host!r}
LOG_DIR = Path({log_dir!r})
LANE_LABEL_PREFIX = {lane_label_prefix!r}
LEGACY_LABEL = {legacy_label!r}
LEGACY_PLIST = {legacy_plist!r}
TARGET_PORTS = {repr(sorted(set(target_ports)))}
ROWS = {repr(rows)}
TEAM_MIN = 8100
TEAM_MAX = 8119

def _launchctl(*argv):
    return subprocess.run(["launchctl", *argv], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)

LOG_DIR.mkdir(parents=True, exist_ok=True)

# Disable legacy supervisor path.
_launchctl("bootout", f"system/{{LEGACY_LABEL}}")
_launchctl("bootout", "system", LEGACY_PLIST)
_launchctl("disable", f"system/{{LEGACY_LABEL}}")

wanted_ports = {{int(row["port"]) for row in ROWS}}
ports_to_consider = TARGET_PORTS if TARGET_PORTS else list(range(TEAM_MIN, TEAM_MAX + 1))
for port in ports_to_consider:
    label = f"{{LANE_LABEL_PREFIX}}.{{port}}"
    plist = f"/Library/LaunchDaemons/{{label}}.plist"
    if int(port) not in wanted_ports:
        _launchctl("bootout", f"system/{{label}}")
        _launchctl("bootout", "system", plist)
        _launchctl("disable", f"system/{{label}}")

started = []
for row in sorted(ROWS, key=lambda r: int(r["port"])):
    label = f"{{LANE_LABEL_PREFIX}}.{{row['port']}}"
    plist = Path(f"/Library/LaunchDaemons/{{label}}.plist")
    env = dict(row.get("env") or {{}})
    env["PATH"] = "/opt/homebrew/bin:/Users/thestudio/.local/bin:/Users/thestudio/.venv-vllm-metal/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    plist_payload = {{
        "Label": label,
        "ProgramArguments": list(row.get("argv") or []),
        "EnvironmentVariables": env,
        "RunAtLoad": True,
        "KeepAlive": True,
        "ThrottleInterval": 30,
        "ProcessType": "Interactive",
        "WorkingDirectory": "/opt/mlx-launch",
        "StandardOutPath": str(LOG_DIR / f"vllm-{{row['port']}}.log"),
        "StandardErrorPath": str(LOG_DIR / f"vllm-{{row['port']}}.err.log"),
    }}
    with plist.open("wb") as handle:
        plistlib.dump(plist_payload, handle, fmt=plistlib.FMT_XML, sort_keys=False)
    os.chmod(plist, 0o644)
    _launchctl("enable", f"system/{{label}}")
    _launchctl("bootout", f"system/{{label}}")
    _launchctl("bootout", "system", str(plist))
    out = subprocess.run(["launchctl", "bootstrap", "system", str(plist)], text=True, capture_output=True, check=False)
    if out.returncode != 0:
        raise SystemExit(f"failed to bootstrap {{label}}: {{out.stderr.strip() or out.stdout.strip()}}")
    _launchctl("kickstart", "-k", f"system/{{label}}")
    started.append({{
        "label": label,
        "port": row["port"],
        "model": row["model"],
        "profile": row.get("profile"),
        "tool_choice_mode": row.get("tool_choice_mode"),
        "tool_call_parser_resolved": row.get("tool_call_parser_resolved"),
    }})

print(json.dumps({{"started": started}}, indent=2))
"""
    _studio_sudo_cmd(studio_ssh, ["python3", "-"], input_bytes=script.encode("utf-8"), check=True)
    scope = ",".join(str(p) for p in sorted(set(target_ports))) if target_ports else "all assigned team lanes"
    print(f"started per-lane supervisor labels ({lane_label_prefix}.*) for {scope}")


def cmd_repair_lanes(args):
    studio_ssh = os.environ.get("STUDIO_SSH", "studio")
    if _is_local_host():
        data = _load_registry(_registry_path())
    else:
        data = _fetch_registry_from_studio(studio_ssh, os.environ.get("MLX_REGISTRY_PATH", DEFAULT_REGISTRY))
    remote_status_by_port = {}
    if not _is_local_host():
        studio_cmd = os.environ.get("STUDIO_MLXCTL", "/Users/thestudio/bin/mlxctl")
        status_result = _ssh_cmd(studio_ssh, [studio_cmd, "--local", "status", "--checks", "--json"], check=True)
        status_payload = _loads_json_or_die(
            (status_result.stdout or b"").decode("utf-8", errors="replace"),
            context="repair-lanes remote status payload",
            default="{}",
        )
        for row in status_payload.get("ports") or []:
            try:
                remote_status_by_port[int(row.get("port"))] = row
            except Exception:
                continue
    requested_ports = set(
        _parse_port_csv(
            getattr(args, "ports", ""),
            arg_name="--ports",
            valid_range=TEAM_RANGE,
            range_label="8100-8119",
        )
    )
    assigned_ports = sorted(
        int(entry.get("port"))
        for entry in data["models"].values()
        if entry.get("port") and int(entry.get("port")) in TEAM_RANGE
    )
    if requested_ports:
        assigned_ports = [port for port in assigned_ports if port in requested_ports]
    disabled_map = _launchctl_disabled_map()
    repairs = []
    for port in assigned_ports:
        if _is_local_host():
            lane_state = _lane_launchd_state(port, disabled_map=disabled_map)
            listener_visible = bool(_port_listening(port))
            process_visible = bool(_mlx_pids_for_port(port))
            http_models_ok = _models_endpoint_ok(port)
        else:
            status_row = remote_status_by_port.get(port) or {}
            lane_state = {
                "label": status_row.get("launchd_label") or _lane_label(port),
                "loaded": status_row.get("launchd_loaded"),
                "disabled": status_row.get("launchd_disabled"),
            }
            listener_visible = bool(status_row.get("listener_visible"))
            status_text = str(status_row.get("status") or "").strip().lower()
            process_visible = status_text in {"running", "listening"}
            http_models_ok = bool(status_row.get("http_models_ok"))
        needs_repair = bool(
            lane_state["disabled"] is True
            or lane_state["loaded"] is False
            or not (listener_visible or process_visible or http_models_ok)
        )
        if not needs_repair:
            continue
        reasons = []
        if lane_state["disabled"] is True:
            reasons.append("launchd-disabled")
        if lane_state["loaded"] is False:
            reasons.append("launchd-unloaded")
        if not (listener_visible or process_visible or http_models_ok):
            reasons.append("lane-down")
        repairs.append(
            {
                "port": port,
                "label": lane_state["label"],
                "launchd_loaded": lane_state["loaded"],
                "launchd_disabled": lane_state["disabled"],
                "listener_visible": listener_visible,
                "process_visible": process_visible,
                "http_models_ok": http_models_ok,
                "reasons": reasons,
            }
        )

    if args.apply:
        failures = []
        for row in repairs:
            label = row["label"]
            plist = f"/Library/LaunchDaemons/{label}.plist"
            step_results = []
            commands = [
                ("enable", f"launchctl enable system/{shlex.quote(label)}"),
                ("bootout_label", f"launchctl bootout system/{shlex.quote(label)}"),
                ("bootout_plist", f"launchctl bootout system {shlex.quote(plist)}"),
                ("bootstrap", f"launchctl bootstrap system {shlex.quote(plist)}"),
                ("kickstart", f"launchctl kickstart -k system/{shlex.quote(label)}"),
            ]
            for step_name, command in commands:
                result = _studio_sudo_cmd(studio_ssh, command, check=False)
                stderr = (result.stderr or b"").decode("utf-8", errors="replace").strip()
                stdout = (result.stdout or b"").decode("utf-8", errors="replace").strip()
                step_results.append(
                    {
                        "step": step_name,
                        "returncode": result.returncode,
                        "stderr": stderr,
                        "stdout": stdout,
                    }
                )
                if step_name == "bootstrap" and result.returncode != 0:
                    break
            bootstrap_step = next((item for item in step_results if item["step"] == "bootstrap"), None)
            apply_ok = bool(bootstrap_step and bootstrap_step["returncode"] == 0)
            row["apply_result"] = {"success": apply_ok, "steps": step_results}
            if not apply_ok:
                err_msg = ""
                if bootstrap_step:
                    err_msg = bootstrap_step.get("stderr") or bootstrap_step.get("stdout") or "bootstrap failed"
                failures.append(f"{label}: {err_msg}")
        if failures:
            raise SystemExit("repair-lanes apply failed:\n  - " + "\n  - ".join(failures))

    payload = {
        "mode": "apply" if args.apply else "dry-run",
        "scoped_assigned_ports": assigned_ports,
        "repair_count": len(repairs),
        "repairs": repairs,
    }
    if args.json:
        print(json.dumps(payload, indent=2))
        return
    if not repairs:
        print(f"repair-lanes ({payload['mode']}): no lane repair actions needed")
        return
    print(f"repair-lanes ({payload['mode']}): {len(repairs)} lane(s) need repair")
    for row in repairs:
        print(
            f"- {row['label']} @ {row['port']} "
            f"(loaded={row['launchd_loaded']} disabled={row['launchd_disabled']} "
            f"listener={row['listener_visible']} process={row['process_visible']} "
            f"reasons={','.join(row['reasons'])})"
        )
    if not args.apply:
        print("no changes written (use --apply to repair lane labels)")

def _collect_offload_candidates(studio_ssh: str):
    script = """
import json
from pathlib import Path

hub = Path("/Users/thestudio/models/hf/hub")
reg = hub / "registry.json"
if not reg.exists():
    raise SystemExit(0)
data = json.loads(reg.read_text() or "{}")
models = data.get("models", {})
for entry in models.values():
    og_path = entry.get("og_path")
    cache_path = entry.get("cache_path")
    if not og_path or not cache_path:
        continue
    if og_path == cache_path:
        continue
    try:
        og_path = Path(og_path)
        rel = og_path.relative_to(hub)
    except Exception:
        continue
    print(str(rel))
"""
    result = subprocess.run(
        ["ssh", studio_ssh, "python3", "-"],
        input=script.encode("utf-8"),
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit("failed to build offload list from studio registry")
    lines = [line.strip() for line in result.stdout.decode("utf-8").splitlines() if line.strip()]
    return lines


def cmd_offload_og(args):
    studio_ssh = os.environ.get("STUDIO_SSH", "thestudio@192.168.1.72")
    offload_script = Path(os.environ.get("MLX_OFFLOAD_SCRIPT", DEFAULT_OFFLOAD_SCRIPT))

    candidates = _collect_offload_candidates(studio_ssh)
    if not candidates:
        print("no offload candidates found")
        return
    if args.dry_run:
        print("\n".join(candidates))
        return

    with tempfile.NamedTemporaryFile("w", delete=False) as handle:
        for line in candidates:
            handle.write(line + "\n")
        list_path = handle.name

    if offload_script.exists():
        env = os.environ.copy()
        env["MLX_OFFLOAD_ALLOW"] = "1"
        env["MLX_OFFLOAD_LIST"] = list_path
        env.setdefault("STUDIO_SSH", studio_ssh)
        subprocess.run([str(offload_script)], env=env, check=False)
        return

    offload_host = os.environ.get("MLX_OFFLOAD_HOST", "mini")
    if not offload_host:
        raise SystemExit(f"offload script not found locally and MLX_OFFLOAD_HOST not set: {offload_script}")

    remote_list = f"/tmp/mlx_offload_{os.getpid()}.txt"
    subprocess.run(
        ["ssh", offload_host, f"cat > {remote_list}"],
        input=Path(list_path).read_bytes(),
        check=False,
    )
    env_parts = [
        "MLX_OFFLOAD_ALLOW=1",
        f"MLX_OFFLOAD_LIST={remote_list}",
        f"STUDIO_SSH={studio_ssh}",
    ]
    subprocess.run(
        ["ssh", offload_host, " ".join(env_parts + [str(offload_script)])],
        check=False,
    )
    subprocess.run(["ssh", offload_host, "rm", "-f", remote_list], check=False)


def main():
    parser = argparse.ArgumentParser(
        prog="mlxctl",
        description=(
            "MLX model registry + port controller for the Studio. "
            "Manages HF cache, registry.json, MLX servers, and LiteLLM sync."
        ),
        epilog=(
            "Naming (default): model_id becomes 'mlx-<family>-<params>-<quant>-<variant>'.\n"
            "Order matters: family → parameter count → quant → other identifiers (e.g., instruct).\n"
            "Repo org is stripped; dash-only; use --name only for exceptions.\n\n"
            "Mutating commands require local/Studio mlxctl parity.\n"
            "Use `mlxctl studio-cli-sha` and `mlxctl sync-studio-cli`.\n\n"
            "Common commands:\n"
            "  mlxctl list\n"
            "  mlxctl status\n"
            "  mlxctl studio-cli-sha\n"
            "  mlxctl sync-studio-cli\n"
            "  mlxctl load <repo_id> 8101\n"
            "  mlxctl unload 8101\n"
            "  mlxctl sync-gateway\n\n"
            "Ports:\n"
            "  8100-8119 team, 8120-8139 experimental\n"
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("--local", action="store_true", help="run locally on Studio")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("init", help="Scan HF cache and initialize registry entries")
    sub.add_parser("list", help="List registered MLX models (model_id, repo_id, port, ctx, max_out)")
    status = sub.add_parser("status", help="Show MLX port status and routing mode")
    status.add_argument("--checks", action="store_true", help="Include runtime family/model-path checks")
    status.add_argument("--json", action="store_true", help="Emit JSON payload only (unless --table is also set)")
    status.add_argument("--table", action="store_true", help="Print table output even when --json is set")
    omni_install = sub.add_parser("omni-install", help="Install + run mlx-omni-server on the Studio (canary)")
    omni_install.add_argument("--port", type=int, default=8120, help="Port to run omni on (default: 8120)")
    omni_install.add_argument("--host", default="0.0.0.0", help="Bind address (default: 0.0.0.0)")
    omni_stop = sub.add_parser("omni-stop", help="Stop mlx-omni-server launchd job on the Studio")
    omni_stop.add_argument("--port", type=int, default=8120, help="Port label to stop (default: 8120)")
    omni_status = sub.add_parser("omni-status", help="Check mlx-omni-server status on the Studio")
    omni_status.add_argument("--port", type=int, default=8120, help="Port to check (default: 8120)")
    omni_warm = sub.add_parser("omni-warm", help="Warm models into mlx-omni-server cache (Omni-first)")
    omni_warm.add_argument("models", nargs="+", help="Model IDs to warm (e.g. openai/mlx-..., mlx-..., etc.)")
    omni_warm.add_argument("--port", type=int, default=8120, help="Omni port to warm against (default: 8120)")
    omni_warm.add_argument("--timeout", type=int, default=60, help="Per-model request timeout seconds (default: 60)")
    omni_warm.add_argument("--max-tokens", dest="max_tokens", type=int, default=8, help="Warmup max_tokens (default: 8)")
    vllm_caps = sub.add_parser("vllm-capabilities", help="Show discovered vLLM feature support and parser enum")
    vllm_caps.add_argument("--json", action="store_true", help="Emit JSON payload")
    vllm_render = sub.add_parser("vllm-render", help="Render effective per-lane vLLM argv/env from registry")
    vllm_render.add_argument("--ports", default="", help="Optional comma-separated team ports (8100-8119)")
    vllm_render.add_argument("--validate", action="store_true", help="Fail on unsupported parser/auto-tool configuration")
    vllm_render.add_argument("--json", action="store_true", help="Emit JSON payload")
    vllm_set = sub.add_parser("vllm-set", help="Update typed vLLM settings for a registry model")
    vllm_set.add_argument("model", help="Registry model_id slug or repo_id")
    vllm_set.add_argument("--profile", choices=["qwen3_main", "gpt_oss_lane", "generic"])
    vllm_set.add_argument("--max-model-len", type=int)
    vllm_set.add_argument("--memory-fraction")
    vllm_set.add_argument("--tool-choice-mode", choices=["none", "auto"])
    vllm_set.add_argument("--tool-call-parser")
    vllm_set.add_argument("--reasoning-parser")
    vllm_set.add_argument("--clear-vllm", action="store_true", help="Reset nested vllm block to empty object")
    async_group = vllm_set.add_mutually_exclusive_group()
    async_group.add_argument("--async-scheduling", dest="async_scheduling", action="store_true")
    async_group.add_argument("--no-async-scheduling", dest="async_scheduling", action="store_false")
    vllm_set.set_defaults(async_scheduling=None)
    sub.add_parser("mlx-launch-configure-vllm", help="LEGACY: install registry-driven vllm-metal start.sh for com.bebop.mlx-launch")
    mlx_launch_stop = sub.add_parser("mlx-launch-stop", help="Stop managed per-lane launchd labels and clear listeners")
    mlx_launch_stop.add_argument("--ports", default="8100,8101,8102", help="Comma-separated ports to clear listeners")
    mlx_launch_start = sub.add_parser("mlx-launch-start", help="Start managed per-lane launchd labels from registry assignments")
    mlx_launch_start.add_argument("--ports", default="", help="Optional comma-separated team ports (8100-8119) to apply")
    mlx_launch_start.add_argument(
        "--allow-partial",
        action="store_true",
        help="Allow --ports scope that is a strict subset of assigned team lanes",
    )
    repair_lanes = sub.add_parser("repair-lanes", help="Detect/repair disabled or unloaded assigned team lane labels")
    repair_lanes.add_argument("--ports", default="", help="Optional comma-separated team ports (8100-8119) to scope")
    repair_lanes.add_argument("--apply", action="store_true", help="Enable/bootstrap scoped assigned team lanes")
    repair_lanes.add_argument("--json", action="store_true", help="Emit JSON payload")

    load = sub.add_parser("load", help="Download/register a model and launch on a port")
    load.add_argument("model", help="HF repo_id or existing registry model_id")
    load.add_argument("port", help="Port number (8100-8139) or 'auto' for 8120+")
    load.add_argument("--force", action="store_true", help="Force reload even if port/model is already assigned")
    load.add_argument("--ignore-launchd", action="store_true", help="Skip launchd stop prompt")
    load.add_argument("--convert", choices=["auto", "force", "skip"], default="auto")
    load.add_argument("--name", help="Canonical model id override (defaults to mlx-<repo-name>, no org prefix)")
    load.add_argument("--no-offload-og", dest="offload_og", action="store_false", help="Skip offloading OG weights after conversion")
    load.set_defaults(offload_og=True)
    load.add_argument(
        "--preconverted",
        choices=["yes", "no", "auto"],
        default="auto",
        help="Override pre-converted detection (yes|no|auto)",
    )
    load.add_argument("--no-sync", dest="sync", action="store_false", help="Skip gateway sync after load")
    load.set_defaults(sync=True)

    unload = sub.add_parser("unload", help="Stop server on a port and clear registry assignment")
    unload.add_argument("port", help="Port number (8100-8139)")
    unload.add_argument("--no-sync", dest="sync", action="store_false", help="Skip gateway sync after unload")
    unload.set_defaults(sync=True)

    unload_all = sub.add_parser("unload-all", help="Stop all MLX servers and clear assignments")
    unload_all.add_argument("--no-sync", dest="sync", action="store_false", help="Skip gateway sync after unload-all")
    unload_all.set_defaults(sync=True)
    reconcile = sub.add_parser("reconcile", help="Find stale registry assignments; mutation requires --apply")
    reconcile.add_argument("--apply", action="store_true", help="Clear stale registry assignments")
    reconcile.add_argument("--json", action="store_true", help="Emit JSON reconciliation payload")
    verify = sub.add_parser("verify", help="Validate registry vs gateway config")
    verify.add_argument(
        "--fix-defaults",
        action="store_true",
        help="Persist inferred defaults (context/parser/template fields) before validation",
    )
    # Deprecated: ensemble (kept for backward compatibility)
    ensemble = sub.add_parser("ensemble", help="DEPRECATED: use load/assign-team instead")
    ensemble.add_argument("name", help="Deprecated")
    ensemble.add_argument("--force", action="store_true")
    ensemble.add_argument("--ignore-launchd", action="store_true")
    ensure = sub.add_parser("ensure", help="Ensure model is in registry (optionally load)")
    ensure.add_argument("repo", help="HF repo_id")
    ensure.add_argument("--name", help="Canonical model id override (defaults to mlx-<repo-name>, no org prefix)")
    ensure.add_argument("--convert", choices=["auto", "force", "skip"], default="auto")
    ensure.add_argument("--no-offload-og", dest="offload_og", action="store_false")
    ensure.set_defaults(offload_og=True)
    ensure.add_argument(
        "--preconverted",
        choices=["yes", "no", "auto"],
        default="auto",
        help="Override pre-converted detection (yes|no|auto)",
    )
    ensure.add_argument("--load", action="store_true", help="Load the model after ensuring it")
    ensure.add_argument("--port", default="auto", help="Port number (8100-8139) or 'auto' for 8120+")
    ensure.add_argument("--no-sync", dest="sync", action="store_false")
    ensure.set_defaults(sync=True)
    offload = sub.add_parser("offload-og", help="Offload OG base weights not used for inference")
    offload.add_argument("--dry-run", action="store_true")
    sync = sub.add_parser("sync-gateway", help="Sync MLX registry to LiteLLM router/env")
    sync.add_argument("--dry-run", action="store_true")
    assign = sub.add_parser("assign-team", help="Assign MLX models to team ports by size")
    assign.add_argument("--dry-run", action="store_true")
    assign.add_argument("--no-sync", dest="sync", action="store_false")
    assign.set_defaults(sync=True)
    sub.add_parser("studio-cli-sha", help="Show local and Studio mlxctl SHA256 parity")
    sub.add_parser("sync-studio-cli", help="Copy local mlxctl to Studio and verify SHA256 parity")

    args = parser.parse_args()
    _enforce_studio_cli_parity(args)
    _maybe_forward_to_studio(args)

    commands = {
        "init": cmd_init,
        "list": cmd_list,
        "status": cmd_status,
        "omni-install": cmd_omni_install,
        "omni-stop": cmd_omni_stop,
        "omni-status": cmd_omni_status,
        "omni-warm": cmd_omni_warm,
        "vllm-capabilities": cmd_vllm_capabilities,
        "vllm-render": cmd_vllm_render,
        "vllm-set": cmd_vllm_set,
        "mlx-launch-configure-vllm": cmd_mlx_launch_configure_vllm,
        "mlx-launch-stop": cmd_mlx_launch_stop,
        "mlx-launch-start": cmd_mlx_launch_start,
        "repair-lanes": cmd_repair_lanes,
        "load": cmd_load,
        "unload": cmd_unload,
        "unload-all": cmd_unload_all,
        "reconcile": cmd_reconcile,
        "verify": cmd_verify,
        "ensemble": cmd_ensemble,
        "ensure": lambda args: cmd_ensure(args),
