        "sync-gateway": cmd_sync_gateway,
        "assign-team": cmd_assign_team,
        "studio-cli-sha": cmd_studio_cli_sha,
        "sync-studio-cli": cmd_sync_studio_cli,
    }
    commands[args.command](args)


if __name__ == "__main__":
    main()
