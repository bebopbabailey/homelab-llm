[Unit]
Description=CCProxy API (Codex sidecar)
After=network.target

[Service]
Type=simple
User=christopherbailey
WorkingDirectory=/home/christopherbailey/homelab-llm/experiments/ccproxy-api
EnvironmentFile=/etc/homelab-llm/ccproxy.env
ExecStart=/home/christopherbailey/homelab-llm/experiments/ccproxy-api/scripts/run_ccproxy.sh
