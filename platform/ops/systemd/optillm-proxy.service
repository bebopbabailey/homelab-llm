[Unit]
Description=OptiLLM Proxy (optillm-proxy)
After=network.target

[Service]
Type=simple
User=christopherbailey
WorkingDirectory=/home/christopherbailey/homelab-llm/layer-gateway/optillm-proxy
EnvironmentFile=/etc/optillm-proxy/env
ExecStart=/home/christopherbailey/homelab-llm/layer-gateway/optillm-proxy/.venv/bin/optillm --host 192.168.1.72 --port 4020 --base-url http://192.168.1.71:4000/v1 --approach proxy --model main
Restart=always
RestartSec=2
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
