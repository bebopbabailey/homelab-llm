{
  "version": 1,
  "servers": [
    {
      "name": "web-fetch",
      "purpose": "fetch + clean HTML",
      "transport": "stdio",
      "command": "/home/christopherbailey/.local/bin/uv",
      "args": [
        "run",
        "--directory",
        "/home/christopherbailey/homelab-llm/services/mcp-tools/web-fetch",
        "python",
        "-m",
        "web_fetch_mcp"
      ],
      "env": [
        "LITELLM_SEARCH_API_BASE",
        "LITELLM_SEARCH_API_KEY",
        "WEB_FETCH_USER_AGENT"
      ],
      "tools": [
        "search.web",
        "web.fetch"
      ],
      "notes": "Returns cleaned text plus optional raw HTML."
    }
  ]
}
