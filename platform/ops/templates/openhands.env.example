# Non-secret runtime defaults for the managed OpenHands Phase A service.
# Install this as /etc/openhands/env on the Mini.
# Do not store provider credentials or LiteLLM worker keys here.
# Phase A provider/API keys remain UI-entered only.

OPENHANDS_CONTAINER_NAME=openhands-app
OPENHANDS_HOST_PORT=4031
OPENHANDS_APP_IMAGE=docker.openhands.dev/openhands/openhands:1.5
OPENHANDS_RUNTIME_IMAGE=docker.openhands.dev/openhands/runtime:latest-nikolaik
OPENHANDS_AGENT_SERVER_IMAGE_REPOSITORY=ghcr.io/openhands/agent-server
OPENHANDS_AGENT_SERVER_IMAGE_TAG=1.12.0-python
OPENHANDS_LOG_ALL_EVENTS=true
OPENHANDS_WORKSPACE_DIR=/home/christopherbailey/openhands-experimental/phase-a-workspace
OPENHANDS_PERSISTENCE_DIR=/home/christopherbailey/.local/share/openhands-phasea

# LiteLLM Phase B remains out of scope for this env file.
