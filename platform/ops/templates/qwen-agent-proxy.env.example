# Non-secret runtime defaults for qwen-agent-proxy.
# Install as /etc/homelab-llm/qwen-agent-proxy.env on the Mini.
# Keep QWEN_AGENT_PROXY_AUTH_TOKEN in a separate local-only secret env.

# Use 127.0.0.1 for host-local operator probes.
# Use 172.17.0.1 when a Docker container must reach the sidecar via
# host.docker.internal without exposing it on the LAN.
QWEN_AGENT_PROXY_HOST=127.0.0.1
QWEN_AGENT_PROXY_PORT=4021
QWEN_AGENT_PROXY_MODEL_ID=qwen-agent-coder-next-shadow
QWEN_AGENT_PROXY_BACKEND_BASE_URL=http://127.0.0.1:18134/v1
QWEN_AGENT_PROXY_BACKEND_MODEL=mlx-qwen3-coder-next-4bit-shadow
QWEN_AGENT_PROXY_BACKEND_API_KEY=EMPTY
QWEN_AGENT_PROXY_USE_RAW_API=false
QWEN_AGENT_PROXY_DEFAULT_MAX_TOKENS=1024
QWEN_AGENT_PROXY_DEFAULT_TEMPERATURE=0.0
