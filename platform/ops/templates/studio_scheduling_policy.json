{
  "version": 1,
  "owned_namespaces": [
    "com.bebop.",
    "com.deploy."
  ],
  "unmanaged_policy": "quarantine",
  "quarantine_dir": "/Library/LaunchDaemons/.quarantine",
  "utility_lane": {
    "taskpolicy_args": [
      "-c",
      "utility",
      "-d",
      "throttle",
      "-g",
      "throttle",
      "-b"
    ],
    "default_nice": 10
  },
  "lane_defaults": {
    "inference": {
      "required_keys": {
        "ProcessType": "Interactive"
      },
      "forbidden_keys": [
        "Nice",
        "LowPriorityIO",
        "LowPriorityBackgroundIO"
      ]
    },
    "background": {
      "required_keys": {
        "ProcessType": "Background",
        "Nice": 10,
        "LowPriorityIO": true,
        "LowPriorityBackgroundIO": true
      },
      "forbidden_keys": []
    },
    "retired": {
      "required_disabled": true
    }
  },
  "managed_labels": {
    "com.bebop.mlx-lane.8100": {
      "lane": "inference",
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-lane.8100.plist"
    },
    "com.bebop.mlx-lane.8101": {
      "lane": "inference",
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-lane.8101.plist"
    },
    "com.bebop.mlx-lane.8102": {
      "lane": "inference",
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-lane.8102.plist"
    },
    "com.bebop.llmster-gpt.8126": {
      "lane": "inference",
      "plist_path": "/Library/LaunchDaemons/com.bebop.llmster-gpt.8126.plist"
    },
    "com.bebop.optillm-proxy": {
      "lane": "inference",
      "plist_path": "/Library/LaunchDaemons/com.bebop.optillm-proxy.plist"
    },
    "com.bebop.pgvector-main": {
      "lane": "background",
      "plist_path": "/Library/LaunchDaemons/com.bebop.pgvector-main.plist"
    },
    "com.bebop.memory-api-main": {
      "lane": "background",
      "plist_path": "/Library/LaunchDaemons/com.bebop.memory-api-main.plist"
    },
    "com.bebop.memory-ingest-nightly": {
      "lane": "background",
      "plist_path": "/Library/LaunchDaemons/com.bebop.memory-ingest-nightly.plist"
    },
    "com.bebop.memory-backup-nightly": {
      "lane": "background",
      "plist_path": "/Library/LaunchDaemons/com.bebop.memory-backup-nightly.plist"
    }
  },
  "retired_labels": {
    "com.bebop.mlx-launch": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-launch.plist",
      "action": "quarantine"
    },
    "com.bebop.mlx-omni.8100": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-omni.8100.plist",
      "action": "quarantine"
    },
    "com.bebop.mlx-omni.8120": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-omni.8120.plist",
      "action": "quarantine"
    },
    "com.bebop.llama-router.8100": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.llama-router.8100.plist",
      "action": "quarantine"
    },
    "com.bebop.mlx-shadow.8123": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-shadow.8123.plist",
      "action": "quarantine"
    },
    "com.bebop.mlx-shadow.8124": {
      "plist_path": "/Library/LaunchDaemons/com.bebop.mlx-shadow.8124.plist",
