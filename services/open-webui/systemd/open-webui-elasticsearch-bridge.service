[Unit]
Description=Open WebUI Elasticsearch localhost bridge to Studio
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=christopherbailey
ExecStart=/usr/bin/ssh -NT -o ExitOnForwardFailure=yes -o ServerAliveInterval=30 -o ServerAliveCountMax=3 -o StrictHostKeyChecking=yes -L 127.0.0.1:19200:127.0.0.1:9200 studio
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
