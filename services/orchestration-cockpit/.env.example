# Local-only manual env for non-systemd runs.
# Do not commit real secrets.
# Durable service env authority lives under /etc/orchestration-cockpit/.

OMLX_RUNTIME_BASE_URL=http://127.0.0.1:8129
OMLX_RUNTIME_BEARER_TOKEN=eval-key
OMLX_RUNTIME_MODEL=Qwen3-4B-Instruct-2507-4bit
OMLX_RUNTIME_TIMEOUT_SECONDS=120
ORCHESTRATION_COCKPIT_GRAPH_ID=operator-cockpit
ORCHESTRATION_COCKPIT_REPO_ROOT=/home/christopherbailey/homelab-llm
ORCHESTRATION_COCKPIT_STATE_DIR=/home/christopherbailey/.local/state/orchestration-cockpit
ORCHESTRATION_COCKPIT_GRAPH_RUNTIME_DIR=/home/christopherbailey/.local/state/orchestration-cockpit/langgraph-runtime
ORCHESTRATION_COCKPIT_ARTIFACT_DIR=/home/christopherbailey/.local/state/orchestration-cockpit
UV_PROJECT_ENVIRONMENT=/home/christopherbailey/.local/share/orchestration-cockpit/graph-venv

# Local tooling prerequisite only if langgraph dev still requires it.
# Not used by Agent Chat UI for local connection.
LANGSMITH_API_KEY=
