use_default_settings: true

general:
  debug: false
  instance_name: "SearXNG"

search:
  safe_search: 0
  autocomplete: "duckduckgo"
  formats:
    - html
    - json

server:
  secret_key: "change-me"
  bind_address: "127.0.0.1"
  port: 8888
  limiter: true
  image_proxy: false

engines:
  - name: bing
    disabled: false
  - name: bing news
    disabled: false
  - name: mojeek
    disabled: true
  - name: karmasearch
    disabled: true
  - name: karmasearch videos
    disabled: true
